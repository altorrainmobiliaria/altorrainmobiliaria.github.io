{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/brain-check.mjs --boot",
            "timeout": 30,
            "statusMessage": "Auto-auditoria del cerebro (brain:check --boot)…"
          },
          {
            "type": "command",
            "command": "node scripts/session-handoff.mjs --boot-echo",
            "timeout": 15,
            "statusMessage": "Handoff automático de la sesión anterior…"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/session-handoff.mjs --precompact",
            "timeout": 15,
            "statusMessage": "Caja negra: volcando foto de sesión (TODO-28 #1)…"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/session-handoff.mjs --end",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/session-handoff.mjs --end",
            "timeout": 15,
            "async": true
          }
        ]
      }
    ]
  }
}
