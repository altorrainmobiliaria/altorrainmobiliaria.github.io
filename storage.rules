rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Imágenes de propiedades — lectura pública, escritura solo admin autenticado
    match /propiedades/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024  // máx 5 MB por archivo
        && request.resource.contentType.matches('image/.*');
    }

    // Multimedia general (logos, hero images, etc.)
    match /multimedia/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Denegar todo lo demás
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
