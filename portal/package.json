{
  "name": "altorra-portal",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Portal ALTORRA Inmobiliaria — Astro + Cloudflare Workers (greenfield, MEGA-PLAN Ola 0)",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "deploy": "wrangler deploy",
    "verify:build": "node ./scripts/verify-build.mjs",
    "verify:data": "node ./scripts/verify-data-invariants.mjs",
    "test": "vitest run",
    "test:rules": "firebase emulators:exec --only firestore --config firebase/firebase.json --project demo-altorra \"vitest run --config vitest.rules.config.ts\"",
    "seed:preview": "node ./firebase/seed/generar-propiedades.mjs --print",
    "cf-types": "wrangler types"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.2",
    "astro": "^7.0.7"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "firebase": "^12.16.0",
    "typescript": "^7.0.2",
    "vitest": "^3.2.7",
    "wrangler": "^4.110.0"
  }
}
