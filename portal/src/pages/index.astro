  .home-arr__chip { font-size: 12px; font-weight: var(--alt-fw-semibold); color: var(--alt-ink); background: var(--alt-gray-50); padding: 5px 11px; border-radius: var(--alt-r-xs); }
  .home-arr__chip--gold { color: var(--alt-link); background: rgba(212, 175, 55, 0.12); }

  .home-arr__aside { flex: 1 1 220px; min-width: 210px; border-left: 1px solid var(--alt-hairline); padding: 22px 26px; display: flex; flex-direction: column; justify-content: center; gap: 12px; }
  .home-arr__adminlbl { display: block; font-size: 10.5px; font-weight: var(--alt-fw-semibold); letter-spacing: 0.06em; color: var(--alt-text-muted); margin-bottom: 2px; }
  .home-arr__price { display: block; font-family: var(--alt-font-display); font-weight: var(--alt-fw-semibold); font-size: 27px; line-height: 1; color: var(--alt-ink); }
  .home-arr__price small { font-family: var(--alt-font-body); font-size: 13px; font-weight: var(--alt-fw-medium); color: var(--alt-text-muted); }
  .home-arr__actions { display: flex; align-items: center; gap: 14px; }
  .home-arr__contact {
    display: inline-flex; align-items: center; padding: 10px 20px; border-radius: var(--alt-r-pill);
    border: 1px solid var(--alt-hairline-2); background: var(--alt-white);
    color: var(--alt-ink); font-weight: var(--alt-fw-semibold); font-size: 13.5px; text-decoration: none;
    transition: border-color var(--alt-dur) var(--alt-ease), color var(--alt-dur) var(--alt-ease), background var(--alt-dur) var(--alt-ease);
  }
  .home-arr__contact:hover { border-color: var(--alt-gold); color: var(--alt-link); background: var(--alt-gray-50); }

  .home-arr__empty { margin-top: 20px; font-size: 14.5px; color: var(--alt-text); }

  @media (max-width: 720px) {
    .home-arr__media { flex-basis: 100%; width: 100%; min-height: 200px; }
    .home-arr__aside { border-left: 0; border-top: 1px solid var(--alt-hairline); flex-basis: 100%; }
    .home-arr__row:hover { transform: none; }
