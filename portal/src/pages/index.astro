  .home-arr__info { flex: 3 1 320px; min-width: 260px; padding: 22px 26px; display: flex; flex-direction: column; justify-content: center; gap: 9px; }
  .home-arr__topline { display: flex; align-items: center; gap: 10px; }
  .home-arr__kicker { font-size: 10px; font-weight: var(--alt-fw-bold); letter-spacing: 0.14em; text-transform: uppercase; color: var(--alt-link); }
  .home-arr__dot { width: 5px; height: 5px; border-radius: 50%; background: var(--alt-gold); flex: none; }
  .home-arr__zona { display: inline-flex; align-items: center; gap: 5px; font-size: 12.5px; color: var(--alt-text); }
