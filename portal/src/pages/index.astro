                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-8.5 8.5 8.5 8.5 0 0 1-3.6-.8L3 21l1.9-5.7A8.38 8.38 0 0 1 4 11.5 8.5 8.5 0 0 1 12.5 3 8.38 8.38 0 0 1 21 11.5z"/></svg>
                  {p.comments}
                </span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ===== HERO — carrusel de 4 banners + buscador superpuesto ===== */
  .home-hero { position: relative; background: var(--alt-surface-neu); padding-bottom: clamp(40px, 6vw, 72px); }
  .home-hero__car { position: relative; overflow: hidden; height: clamp(548px, 60vh, 580px); }

  .hbn { position: absolute; inset: 0; opacity: 0; pointer-events: none; transition: opacity 0.9s ease; background: #fff; }
  .hbn[data-active='1'] { opacity: 1; pointer-events: auto; }
  .hbn--split { background: var(--alt-surface-neu); }
  .hbn__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .hbn[data-active='1'] .hbn__img { animation: hkenburns 9s ease-out both; }
  @keyframes hkenburns { from { transform: scale(1); } to { transform: scale(1.12); } }

  .hbn__wash { position: absolute; inset: 0; pointer-events: none; }
  .hbn__wash--x { background: linear-gradient(92deg, rgba(255, 255, 255, 0.97) 0%, rgba(255, 255, 255, 0.9) 33%, rgba(255, 255, 255, 0.52) 56%, rgba(255, 255, 255, 0) 80%); }
  .hbn__wash--b { background: linear-gradient(0deg, rgba(255, 255, 255, 0.55) 0%, rgba(255, 255, 255, 0) 24%); }

  .hbn__wrap { position: relative; max-width: var(--alt-container); margin: 0 auto; height: 100%; padding: clamp(88px, 10vh, 104px) var(--alt-gutter) clamp(118px, 12vh, 136px); display: flex; align-items: center; }
  .hbn__rise > * { animation: hbnrise 0.85s var(--alt-ease) both; }
  .hbn[data-active='1'] .hbn__rise > *:nth-child(2) { animation-delay: 0.08s; }
  .hbn[data-active='1'] .hbn__rise > *:nth-child(3) { animation-delay: 0.16s; }
  .hbn[data-active='1'] .hbn__rise > *:nth-child(4) { animation-delay: 0.24s; }
  @keyframes hbnrise { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: none; } }
  @media (prefers-reduced-motion: reduce) { .hbn[data-active='1'] .hbn__img { animation: none; } .hbn__rise > * { animation: none !important; } }

  .hbn__h { font-family: var(--alt-font-display); font-weight: var(--alt-fw-bold); line-height: 1.03; letter-spacing: var(--alt-tracking-tight); color: var(--alt-ink); margin: 0 0 16px; font-size: clamp(32px, 4.4vw, 54px); text-wrap: balance; }
  .hbn__gold { color: var(--alt-link-lg); white-space: nowrap; }
  .hbn__p { font-size: clamp(15px, 1.4vw, 18px); line-height: 1.6; color: var(--alt-text); margin: 0 0 22px; max-width: 500px; }
  .hbn__trust { display: flex; align-items: center; gap: 11px; margin-top: 24px; flex-wrap: wrap; }
  .hbn__trust span:not(.hbn__tdot) { font-size: 10.5px; font-weight: var(--alt-fw-semibold); letter-spacing: 0.2em; text-transform: uppercase; color: var(--alt-text); }
  .hbn__tdot { width: 4px; height: 4px; border-radius: 50%; background: var(--alt-gold); }

  /* Botones del hero */
  .hbtn-sig { display: inline-flex; align-items: center; gap: 13px; padding: 14px 16px 14px 28px; border-radius: var(--alt-r-pill); background: var(--alt-grad-gold); color: var(--alt-ink); font-weight: var(--alt-fw-bold); font-size: 15px; text-decoration: none; box-shadow: var(--alt-nm-up), inset 0 1px 0 rgba(255, 255, 255, 0.55); transition: transform var(--alt-dur) var(--alt-ease), box-shadow var(--alt-dur) var(--alt-ease); }
  .hbtn-sig:hover { transform: translateY(-2px); }
  .hbtn-sig__arw { display: inline-flex; width: 30px; height: 30px; border-radius: 50%; background: rgba(6, 39, 67, 0.14); align-items: center; justify-content: center; flex: none; transition: background var(--alt-dur) var(--alt-ease); }
  .hbtn-sig__arw svg { width: 14px; height: 14px; stroke: var(--alt-ink); transition: transform var(--alt-dur) var(--alt-ease); }
  .hbtn-sig:hover .hbtn-sig__arw { background: var(--alt-ink); }
  .hbtn-sig:hover .hbtn-sig__arw svg { stroke: var(--alt-gold-bright); transform: translateX(3px); }
  .hbtn-goldflat { display: inline-flex; align-items: center; padding: 14px 30px; border-radius: var(--alt-r-pill); background: var(--alt-grad-gold); color: var(--alt-ink); font-weight: var(--alt-fw-bold); font-size: 14.5px; text-decoration: none; transition: transform var(--alt-dur) var(--alt-ease), box-shadow var(--alt-dur) var(--alt-ease); }
  .hbtn-goldflat:hover { transform: translateY(-2px); box-shadow: 0 14px 30px -14px rgba(166, 128, 30, 0.6); }
  .hbtn-outline { display: inline-flex; align-items: center; gap: 10px; padding: 13px 26px; border-radius: var(--alt-r-pill); background: transparent; border: 1.5px solid var(--alt-gold); color: var(--alt-link); font-weight: var(--alt-fw-semibold); font-size: 14px; text-decoration: none; transition: background var(--alt-dur) var(--alt-ease), color var(--alt-dur) var(--alt-ease), border-color var(--alt-dur) var(--alt-ease); }
  .hbtn-outline:hover { background: var(--alt-grad-gold); color: var(--alt-ink); border-color: transparent; }

  /* B1 panel blanco */
  .hbn__panel { background: var(--alt-white); border-top: 3px solid var(--alt-gold); border-radius: 3px 3px 14px 14px; padding: clamp(22px, 2.4vw, 30px); box-shadow: 0 46px 100px -38px rgba(27, 39, 51, 0.5); }
  .hbn__panel .hbn__h { font-size: clamp(28px, 3.5vw, 44px); margin-bottom: 12px; }
  .hbn__stats { display: flex; align-items: stretch; border-top: 1px solid var(--alt-hairline); padding-top: 16px; margin-bottom: 18px; }
  .hbn__stats > div { flex: 1; min-width: 0; }
  .hbn__stats b { display: block; font-family: var(--alt-font-display); font-size: clamp(22px, 2.5vw, 27px); font-weight: var(--alt-fw-bold); color: var(--alt-ink); line-height: 1; }
  .hbn__stats span:not(.hbn__statdiv) { display: block; font-size: 11px; color: var(--alt-text-muted); font-weight: var(--alt-fw-semibold); margin-top: 5px; }
  .hbn__statdiv { width: 1px; background: var(--alt-hairline); margin: 2px clamp(10px, 1.4vw, 18px); }

  /* B2 glass */
  .hbn__glass { border-radius: var(--alt-r-xl); padding: clamp(20px, 2.4vw, 28px); }
  .hbn__glass .hbn__h { font-size: clamp(28px, 3.6vw, 44px); margin-bottom: 10px; }
  .hbn__rate { display: flex; align-items: center; gap: 14px; margin-bottom: 12px; flex-wrap: wrap; }
  .hbn__star { display: inline-flex; align-items: center; gap: 6px; color: var(--alt-ink); font-weight: var(--alt-fw-bold); font-size: 14px; }
  .hbn__star svg { width: 16px; height: 16px; color: var(--alt-gold); }
  .hbn__star small { color: var(--alt-text); font-weight: var(--alt-fw-regular); font-size: 13px; }
  .hbn__from { color: var(--alt-text); font-size: 13px; }
  .hbn__from b { color: var(--alt-link); }

  /* B3 split */
  .hbn__split { display: grid; grid-template-columns: 1.02fr 0.98fr; gap: clamp(26px, 3.6vw, 58px); align-items: center; width: 100%; }
  .hbn__frame { position: relative; border-radius: var(--alt-r-lg); overflow: hidden; aspect-ratio: 16 / 9; box-shadow: 0 44px 84px -34px rgba(9, 17, 25, 0.45); }
  .hbn__frame img { width: 100%; height: 100%; object-fit: cover; }
  .hbn__splittext { max-width: 520px; }
  .hbn__splittext .hbn__h { margin-bottom: 18px; }
  .hbn__steps { display: flex; align-items: center; gap: 13px; margin-bottom: 20px; flex-wrap: wrap; }
  .hbn__step { display: flex; align-items: center; gap: 8px; font-size: 13px; font-weight: var(--alt-fw-semibold); color: var(--alt-ink); }
  .hbn__step b { font-family: var(--alt-font-display); font-size: 15px; color: var(--alt-link); font-weight: var(--alt-fw-semibold); }
  .hbn__stepsep { width: 14px; height: 14px; stroke: rgba(166, 128, 30, 0.55); flex: none; }

  /* Barra de progreso segmentada (dots) */
  .home-hero__nav { position: absolute; left: 0; right: 0; bottom: clamp(90px, 10vw, 102px); z-index: 5; display: flex; justify-content: center; pointer-events: none; }
  .home-hero__navin { max-width: var(--alt-container); width: 100%; padding: 0 var(--alt-gutter); display: flex; }
  .hseg-row { display: flex; align-items: center; gap: 9px; pointer-events: auto; }
  .hseg { position: relative; height: 5px; width: 22px; border-radius: var(--alt-r-pill); background: rgba(27, 39, 51, 0.2); overflow: hidden; cursor: pointer; transition: width 0.5s var(--alt-ease), background 0.4s; padding: 0; border: 0; }
  .hseg[data-on='1'] { width: 72px; background: rgba(27, 39, 51, 0.12); }
  .hsegfill { position: absolute; inset: 0; width: 0; background: var(--alt-grad-gold-underline); border-radius: var(--alt-r-pill); }

  @media (max-width: 920px) {
    .hbn__split { grid-template-columns: 1fr; gap: 22px; }
    .hbn__splitmedia { order: -1; }
  }
  @media (max-width: 640px) {
    .home-hero__car { height: clamp(600px, 92vh, 760px); }
    .hbn__wrap { padding-top: clamp(90px, 14vh, 110px); padding-bottom: 128px; }
    .hbn__wash--x { background: linear-gradient(0deg, rgba(255, 255, 255, 0.95), rgba(255, 255, 255, 0.4) 60%, rgba(255, 255, 255, 0) 100%); }
    .hbn__frame { aspect-ratio: 3 / 2; }
  }

  /* Buscador neumórfico — superpuesto sobre el hero (sube dentro con margin negativo) */
  .home-search { position: relative; z-index: 6; max-width: 1080px; margin: clamp(-76px, -4.6vw, -60px) auto 0; padding-inline: clamp(20px, 5vw, 40px); }
  .home-search__card {
    background: var(--alt-surface-neu);
    border-radius: var(--alt-r-xl);
    box-shadow: var(--alt-nm-glass), 0 34px 80px -42px rgba(6, 39, 67, 0.42);
    padding: clamp(16px, 1.6vw, 20px);
  }
  .home-search__tabs {
    display: inline-flex;
    background: var(--alt-surface-neu);
    box-shadow: var(--alt-nm-in-sm);
    border-radius: var(--alt-r-pill);
    padding: 5px;
    gap: 3px;
    flex-wrap: wrap;
  }
  .home-search__tab {
    padding: 9px 20px;
    border: 0;
    border-radius: var(--alt-r-pill);
    background: transparent;
    color: var(--alt-text);
    font-family: var(--alt-font-body);
    font-weight: var(--alt-fw-semibold);
    font-size: 13.5px;
    cursor: pointer;
    transition: color var(--alt-dur) var(--alt-ease), box-shadow var(--alt-dur) var(--alt-ease);
  }
  .home-search__tab[aria-selected='true'] {
    background: var(--alt-surface-neu);
    box-shadow: var(--alt-nm-up-sm);
    color: var(--alt-ink);
  }
  .home-search__row {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 12px;
  }
  .home-search__field {
    flex: 1;
    min-width: 200px;
    display: flex;
    align-items: center;
    gap: 13px;
    padding: 12px 18px;
    background: var(--alt-surface-neu);
    box-shadow: var(--alt-nm-in-sm);
    border-radius: var(--alt-r-md);
  }
  .home-search__field--type { flex: 0 1 190px; min-width: 160px; }
  .home-search__field svg { width: 20px; height: 20px; stroke: var(--alt-gold-raw); flex: none; }
  .home-search__field label { flex: 1; min-width: 0; display: block; }
  .home-search__lbl {
    display: block;
    font-size: 10.5px;
    font-weight: var(--alt-fw-bold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--alt-text-muted);
    margin-bottom: 2px;
  }
  .home-search__field input,
  .home-search__field select {
    width: 100%;
    border: 0;
    outline: none;
    background: none;
    font-family: var(--alt-font-body);
    font-size: 15.5px;
    color: var(--alt-ink);
    padding: 0;
    cursor: pointer;
  }
  .home-search__field input { cursor: text; }
  .home-search__vdiv { width: 1px; align-self: stretch; background: var(--alt-hairline); margin: 6px 4px; }
  .home-search__go {
    flex: none;
    width: 64px;
    height: 64px;
    border: 0;
    border-radius: 50%;
    background: var(--alt-grad-gold-145, linear-gradient(145deg, #ebd27e 0%, #d4af37 52%, #a6801e 100%));
    box-shadow: var(--alt-nm-orb);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-left: auto;
    cursor: pointer;
    transition: transform var(--alt-dur) var(--alt-ease);
  }
  .home-search__go svg { width: 23px; height: 23px; stroke: var(--alt-ink); }
  .home-search__go:hover { transform: scale(1.06); }

  /* CUATRO MANERAS */
  .home-maneras__head { max-width: 640px; margin-bottom: clamp(32px, 5vw, 56px); }
  .home-maneras__head h2 { margin-top: var(--alt-space-3); }
  .home-maneras__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(430px, 100%), 1fr));
    gap: var(--alt-gap-grid);
  }
  .home-manera {
    position: relative;
    display: block;
    border-radius: var(--alt-r-xl);
    overflow: hidden;
    min-height: clamp(280px, 27vw, 360px);
    box-shadow: var(--alt-elev-card);
    text-decoration: none;
    transition: transform var(--alt-dur-slow) var(--alt-ease-card), box-shadow var(--alt-dur-slow) var(--alt-ease-card);
  }
  .home-manera img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform var(--alt-dur-slow) var(--alt-ease-card); }
  .home-manera__scrim { position: absolute; inset: 0; background: var(--alt-scrim-img); }
  .home-manera:hover { transform: translateY(-6px); box-shadow: var(--alt-elev-card-hover); }
  .home-manera:hover img { transform: scale(1.05); }
  .home-manera__body { position: absolute; left: 0; right: 0; bottom: 0; padding: clamp(24px, 2.6vw, 34px); }
  .home-manera__n { display: block; font-family: var(--alt-font-display); font-style: italic; font-size: 17px; color: var(--alt-gold-bright); margin-bottom: 8px; }
  .home-manera__t { display: block; font-family: var(--alt-font-display); font-weight: var(--alt-fw-semibold); font-size: clamp(28px, 2.9vw, 36px); line-height: 1; color: #fff; margin-bottom: 9px; }
  .home-manera__d { display: block; font-size: 14px; line-height: 1.55; color: rgba(255, 255, 255, 0.82); max-width: 330px; margin-bottom: 16px; }
  .home-manera__cta { display: inline-flex; align-items: center; gap: 7px; font-weight: var(--alt-fw-semibold); font-size: 14px; color: #fff; }
  .home-manera__cta svg { width: 15px; height: 15px; transition: transform var(--alt-dur) var(--alt-ease); }
  .home-manera:hover .home-manera__cta svg { transform: translateX(4px); }

  /* Bandas de secciones de propiedades */
  .home-band { padding-block: clamp(60px, 8vw, 110px); border-top: 1px solid var(--alt-hairline); }
  /* Ritmo de fondos del mockup: alterna banda mist (#f2f6f9) con lienzo neu (#E6EDF2).
     El neu es el que permite el neumorfismo (cards con --alt-nm-up). */
  .home-band--alt { background: var(--alt-surface-alt); }
  .home-band--neu { background: var(--alt-surface-neu); }
  .home-sechead { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; flex-wrap: wrap; margin-bottom: clamp(28px, 4vw, 48px); }
  .home-sechead h2 { margin-top: var(--alt-space-3); }
  .home-seelink {
    display: inline-flex; align-items: center; gap: 9px;
    padding: 11px 20px; border-radius: var(--alt-r-pill);
    border: 1px solid var(--alt-hairline-2); background: var(--alt-white);
    color: var(--alt-ink); font-weight: var(--alt-fw-semibold); font-size: 14px; text-decoration: none;
    transition: border-color var(--alt-dur) var(--alt-ease), color var(--alt-dur) var(--alt-ease);
  }
  .home-seelink b { color: var(--alt-link); }
  .home-seelink svg { width: 14px; height: 14px; transition: transform var(--alt-dur) var(--alt-ease); }
  .home-seelink:hover { border-color: var(--alt-gold); }
  .home-seelink:hover svg { transform: translateX(4px); }

  .home-pgrid { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(300px, 100%), 1fr)); gap: clamp(20px, 2.4vw, 32px); }

  /* Card CTA navy (rellena un slot del grid) */
  .home-ctacard { display: flex; flex-direction: column; justify-content: center; align-items: flex-start; padding: 38px 34px; min-height: 250px; }
  .home-ctacard__n { font-family: var(--alt-font-display); font-weight: var(--alt-fw-semibold); font-size: clamp(30px, 3.4vw, 42px); line-height: 1; color: #fff; margin-bottom: 10px; }
  .home-ctacard__d { font-size: 14.5px; line-height: 1.55; color: var(--alt-on-ink-muted); max-width: 230px; margin-bottom: 26px; }

  /* BROKERS (navy) */
  .home-brokers { position: relative; overflow: hidden; background: var(--alt-surface-ink); padding-block: clamp(56px, 7vw, 104px); }
  .home-brokers__glow { position: absolute; top: -25%; right: -8%; width: 52%; height: 150%; background: radial-gradient(circle, rgba(212, 175, 55, 0.2), transparent 66%); pointer-events: none; }
  .home-brokers__in { position: relative; display: grid; grid-template-columns: repeat(auto-fit, minmax(min(340px, 100%), 1fr)); gap: clamp(34px, 4.5vw, 68px); align-items: center; }
  .home-brokers__h { color: #fff; margin: var(--alt-space-3) 0 18px; }
  .home-brokers__p { font-size: clamp(15px, 1.5vw, 18px); line-height: 1.62; color: var(--alt-on-ink-muted); max-width: 470px; margin-bottom: 28px; }
  .home-brokers__perks { display: flex; flex-direction: column; gap: 13px; margin-bottom: 32px; max-width: 440px; }
  .home-brokers__perks li { display: flex; align-items: center; gap: 13px; font-size: 14.5px; color: var(--alt-on-ink); }
  .home-brokers__check { flex: none; width: 26px; height: 26px; border-radius: 50%; background: var(--alt-grad-gold); display: inline-flex; align-items: center; justify-content: center; }
  .home-brokers__check svg { width: 14px; height: 14px; stroke: var(--alt-ink); }
  .home-brokers__cta { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
  .home-brokers__media { position: relative; align-self: stretch; min-height: clamp(320px, 38vw, 440px); border-radius: var(--alt-r-2xl, 22px); overflow: hidden; box-shadow: 0 44px 92px -42px rgba(0, 0, 0, 0.6); }
  .home-brokers__media img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .home-brokers__media-scrim { position: absolute; inset: 0; background: linear-gradient(150deg, rgba(6, 39, 67, 0.5), rgba(6, 39, 67, 0) 55%); }
  .home-brokers__stats { position: absolute; left: 18px; right: 18px; bottom: 18px; display: flex; gap: 12px; flex-wrap: wrap; }
  .home-brokers__stat { padding: 14px 18px; border-radius: var(--alt-r-frame, 14px); }
  .home-brokers__stat-n { display: block; font-family: var(--alt-font-display); font-weight: var(--alt-fw-bold); font-size: 30px; line-height: 1; color: var(--alt-gold-raw); }
  .home-brokers__stat-l { display: block; font-size: 11.5px; font-weight: var(--alt-fw-semibold); color: var(--alt-ink); margin-top: 3px; }

  /* JOURNAL */
  .home-journal { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(320px, 100%), 1fr)); gap: clamp(24px, 3vw, 44px); align-items: start; }
  .home-jmain { display: block; text-decoration: none; }
  .home-jmain__media { position: relative; border-radius: var(--alt-r-xl); overflow: hidden; aspect-ratio: 16 / 10; margin-bottom: 20px; box-shadow: var(--alt-elev-card); }
  .home-jmain__media img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--alt-dur-slow) var(--alt-ease-card); }
  .home-jmain:hover .home-jmain__media img { transform: scale(1.04); }
  .home-jcat { position: absolute; top: 15px; left: 15px; background: rgba(255, 255, 255, 0.95); color: var(--alt-link); padding: 6px 13px; border-radius: var(--alt-r-pill); font-size: 10.5px; font-weight: var(--alt-fw-bold); letter-spacing: 0.12em; text-transform: uppercase; }
  .home-jmeta { display: flex; align-items: center; gap: 10px; font-size: 12px; font-weight: var(--alt-fw-semibold); color: var(--alt-text-muted); margin-bottom: 10px; }
  .home-jdot { width: 3px; height: 3px; border-radius: 50%; background: var(--alt-cloud); }
  .home-jmain__t { font-family: var(--alt-font-display); font-weight: var(--alt-fw-semibold); font-size: clamp(24px, 2.8vw, 34px); line-height: 1.08; color: var(--alt-ink); margin-bottom: 12px; }
  .home-jmain:hover .home-jmain__t { color: var(--alt-link); }
  .home-jmain__x { font-size: 15px; line-height: 1.62; color: var(--alt-text); max-width: 520px; }
  .home-jside { display: flex; flex-direction: column; gap: 22px; }
  .home-jrow { display: flex; gap: 18px; align-items: center; text-decoration: none; }
  .home-jrow__media { position: relative; flex: none; width: clamp(110px, 13vw, 148px); aspect-ratio: 1 / 1; border-radius: var(--alt-r-thumb, 15px); overflow: hidden; box-shadow: var(--alt-elev-card); }
  .home-jrow__media img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--alt-dur-slow) var(--alt-ease-card); }
  .home-jrow:hover .home-jrow__media img { transform: scale(1.05); }
  .home-jrow__cat { display: block; font-size: 10px; font-weight: var(--alt-fw-bold); letter-spacing: 0.12em; text-transform: uppercase; color: var(--alt-link); margin-bottom: 7px; }
  .home-jrow__t { font-family: var(--alt-font-display); font-weight: var(--alt-fw-semibold); font-size: 20px; line-height: 1.1; color: var(--alt-ink); margin-bottom: 8px; }
  .home-jrow:hover .home-jrow__t { color: var(--alt-link); }
  .home-jrow__read { display: block; font-size: 12px; font-weight: var(--alt-fw-semibold); color: var(--alt-text-muted); }

  /* ===== LIENZO DE LA HOME =====
     El mockup declara `body{background:var(--surface)}` con `--surface:#eaf0f7` → la home
     entera vive sobre el LIENZO NEUMÓRFICO, no sobre blanco (ADR §32.15). El D1 ya lo previó:
     `--alt-surface-neu` es OPT-IN para "home+nav". Scoped a esta página: el resto del portal
     conserva el blanco por defecto (mandato de Daniel). Es lo que hace que el neumorfismo lea:
     una card `--alt-nm-up` sobre blanco no tiene relieve, sobre #E6EDF2 sí. */
  main { background: var(--alt-surface-neu); }

  /* ===== EXPLORA POR ZONA — mosaico de 10 tiles de BARRIO ===== */
  .home-zonas { padding-block: clamp(64px, 9vw, 124px); }
  .home-zonas__head { max-width: 640px; }
  .home-zonas__h {
    font-family: var(--alt-font-display); font-weight: var(--alt-fw-semibold);
    font-size: clamp(32px, 4.4vw, 52px); line-height: 1.05; letter-spacing: var(--alt-tracking-tight);
    color: var(--alt-ink); margin: var(--alt-space-3) 0 0; text-wrap: balance;
  }
  .home-zonas__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(210px, 100%), 1fr)); gap: clamp(12px, 1.4vw, 18px); }
  .home-zona {
    position: relative; display: block; overflow: hidden;
    border-radius: 18px; min-height: clamp(240px, 25vw, 300px);
    text-decoration: none;
    box-shadow: var(--alt-nm-up);
    transition: transform var(--alt-dur-slow) var(--alt-ease-card), box-shadow var(--alt-dur-slow) var(--alt-ease-card);
  }
  .home-zona:hover { transform: translateY(-5px); box-shadow: var(--alt-nm-up), 0 34px 66px -36px rgba(6, 39, 67, 0.3); }
  .home-zona img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform var(--alt-dur-slow) var(--alt-ease-card); }
  .home-zona:hover img { transform: scale(1.05); }
  .home-zona__scrim { position: absolute; inset: 0; pointer-events: none; background: linear-gradient(180deg, rgba(27, 39, 51, 0) 42%, rgba(27, 39, 51, 0.84) 100%); }
  .home-zona__body { position: absolute; left: 0; right: 0; bottom: 0; padding: 22px; }
  .home-zona__t { display: block; font-family: var(--alt-font-display); font-weight: var(--alt-fw-semibold); font-size: 23px; line-height: 1; color: #fff; margin-bottom: 6px; }
  .home-zona__n { display: block; font-size: 12px; font-weight: var(--alt-fw-semibold); letter-spacing: 0.04em; color: var(--alt-gold-bright); }

  @media (prefers-reduced-motion: reduce) {
    .home-zona, .home-zona img { transition: none; }
    .home-zona:hover { transform: none; }
    .home-zona:hover img { transform: none; }
  }

  /* ===== CERCA DE TI — split buscador + MAPA ilustrado ===== */
  .home-cerca__in { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(340px, 100%), 1fr)); gap: clamp(30px, 4vw, 58px); align-items: center; }
  .home-cerca__h {
    font-family: var(--alt-font-display); font-weight: var(--alt-fw-semibold);
    font-size: clamp(31px, 4.2vw, 50px); line-height: 1.02; letter-spacing: var(--alt-tracking-tight);
    color: var(--alt-ink); margin: var(--alt-space-3) 0 16px; text-wrap: balance;
  }
  .home-cerca__p { font-size: clamp(15px, 1.5vw, 17px); line-height: 1.62; color: var(--alt-text); margin: 0 0 26px; max-width: 440px; }
  .home-cerca__card {
    background: var(--alt-white); border: 1px solid var(--alt-hairline); border-radius: 18px; padding: 20px;
    box-shadow: 0 2px 6px rgba(27, 39, 51, 0.05), 0 26px 54px -38px rgba(27, 39, 51, 0.3);
  }
  .home-cerca__field {
    display: flex; align-items: center; gap: 10px;
    border: 1px solid var(--alt-hairline-2); border-radius: 12px; padding: 12px 15px; margin-bottom: 14px;
  }
  .home-cerca__field svg { width: 18px; height: 18px; stroke: var(--alt-gold-raw); flex: none; }
  .home-cerca__field input { border: 0; outline: none; width: 100%; font-family: var(--alt-font-body); font-size: 14.5px; color: var(--alt-ink); background: transparent; }
  .home-cerca__ops { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
  .home-cerca__foot { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .home-cerca__count { font-size: 12.5px; color: var(--alt-text); margin: 0; }
  .home-cerca__count b { color: var(--alt-ink); font-weight: var(--alt-fw-bold); }
  .home-cerca__go {
    display: inline-flex; align-items: center; gap: 13px;
    padding: 12px 14px 12px 22px; border-radius: var(--alt-r-pill);
    background: var(--alt-grad-gold); color: var(--alt-ink);
    font-weight: var(--alt-fw-bold); font-size: 14px; letter-spacing: 0.01em; text-decoration: none;
    transition: transform var(--alt-dur) var(--alt-ease);
  }
  .home-cerca__go:hover { transform: translateY(-2px); }
  .home-cerca__arw { display: inline-flex; width: 30px; height: 30px; border-radius: 50%; background: rgba(27, 39, 51, 0.16); align-items: center; justify-content: center; flex: none; transition: background var(--alt-dur) var(--alt-ease); }
  .home-cerca__arw svg { width: 14px; height: 14px; stroke: var(--alt-ink); transition: transform var(--alt-dur-slow) var(--alt-ease), stroke var(--alt-dur) var(--alt-ease); }
  .home-cerca__go:hover .home-cerca__arw { background: var(--alt-ink); }
  .home-cerca__go:hover .home-cerca__arw svg { transform: translateX(3px); stroke: var(--alt-gold-bright); }

  /* El MAPA: panel navy + trama de puntos + calles SVG + pins. Ilustrado, no cartografía. */
  .home-map {
    position: relative; border-radius: 22px; overflow: hidden;
    min-height: clamp(400px, 44vw, 500px);
    background: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px) 0 0 / 22px 22px,
      var(--alt-grad-navy-map);
    box-shadow: 0 40px 90px -44px rgba(6, 39, 67, 0.6);
  }
  .home-map__glow { position: absolute; top: -30%; left: 20%; width: 60%; height: 60%; pointer-events: none; background: radial-gradient(circle, rgba(212, 175, 55, 0.16), transparent 70%); }
  .home-map__streets { position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0.28; }

  .home-map__pin { position: absolute; transform: translate(-50%, -100%); display: inline-flex; transition: transform var(--alt-dur) var(--alt-ease); }
  .home-map__pin:hover { transform: translate(-50%, -100%) scale(1.14); }
  .home-map__halo { position: absolute; left: 50%; bottom: 2px; transform: translateX(-50%); border-radius: 50%; }
  .home-map__halo--gold { width: 26px; height: 26px; background: rgba(235, 210, 126, 0.32); }
  .home-map__halo--white { width: 24px; height: 24px; background: rgba(255, 255, 255, 0.26); }
  .home-map__price {
    position: relative; display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 11px; border-radius: var(--alt-r-pill);
    font-size: 12px; font-weight: var(--alt-fw-bold); color: var(--alt-ink);
    box-shadow: 0 8px 18px -6px rgba(6, 39, 67, 0.55);
  }
  .home-map__price--gold { background: var(--alt-gold-bright); }
  .home-map__price--white { background: #fff; }

  .home-map__mini {
    position: absolute; display: flex; align-items: center; gap: 11px;
    background: #fff; border-radius: 14px; padding: 10px;
    box-shadow: 0 16px 36px -18px rgba(6, 39, 67, 0.6);
  }
  .home-map__mini--bl { left: 18px; bottom: 18px; max-width: 245px; }
  .home-map__mini--tr { right: 18px; top: 18px; max-width: 230px; }
  .home-map__mini img { width: 58px; height: 58px; border-radius: 9px; object-fit: cover; flex: none; }
  .home-map__mini--tr img { width: 52px; height: 52px; }
  .home-map__minitxt { min-width: 0; }
  .home-map__minitag { display: block; font-size: 9.5px; font-weight: var(--alt-fw-bold); letter-spacing: 0.12em; text-transform: uppercase; color: var(--alt-link); margin-bottom: 2px; }
  .home-map__minit { display: block; font-family: var(--alt-font-display); font-weight: var(--alt-fw-semibold); font-size: 16px; color: var(--alt-ink); line-height: 1.05; margin-bottom: 2px; }
  .home-map__minip { display: block; font-size: 12px; font-weight: var(--alt-fw-bold); color: var(--alt-ink); }

  /* Las mini-cards se apilan sobre el mapa: en pantallas chicas se estorban */
  @media (max-width: 520px) { .home-map__mini--tr { display: none; } }
  @media (prefers-reduced-motion: reduce) { .home-map__pin, .home-cerca__go, .home-cerca__arw svg { transition: none; } .home-map__pin:hover { transform: translate(-50%, -100%); } }

  /* ===== CTA CORTA ESTANCIA — banda full-bleed con scrim direccional ===== */
  .home-ctaband { position: relative; overflow: hidden; min-height: clamp(420px, 48vw, 560px); display: flex; align-items: center; }
  .home-ctaband__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  /* El scrim del mockup es rgba(18,22,26,…) = casi NEGRO (prohibido) → navy de paleta */
  .home-ctaband__scrim {
    position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(90deg, rgba(6, 39, 67, 0.9) 0%, rgba(6, 39, 67, 0.56) 42%, rgba(6, 39, 67, 0.08) 72%, rgba(6, 39, 67, 0) 100%);
  }
  /* El wrapper no intercepta clics (deja pasar al fondo); solo el CTA es clicable — como el mockup */
  .home-ctaband__in { position: relative; width: 100%; padding-block: clamp(48px, 6vw, 90px); pointer-events: none; }
  .home-ctaband__text { max-width: 520px; }
  .home-ctaband__eyebrow { color: var(--alt-gold-bright); margin-bottom: 16px; }
  .home-ctaband__h {
    font-family: var(--alt-font-display); font-weight: var(--alt-fw-semibold);
    font-size: clamp(32px, 4.4vw, 52px); line-height: 1.04; letter-spacing: var(--alt-tracking-tight);
    color: #fff; margin: 0 0 18px; text-wrap: balance;
  }
  .home-ctaband__p { font-size: clamp(15px, 1.5vw, 18px); line-height: 1.62; color: rgba(255, 255, 255, 0.78); margin: 0 0 30px; max-width: 430px; }
  .home-ctaband__cta { pointer-events: auto; }

  /* ===== REDES — muro tipo Instagram ===== */
  .home-redes { overflow: hidden; padding-block: clamp(56px, 7vw, 100px); }
  .home-redes__head { text-align: center; margin-bottom: clamp(30px, 4vw, 46px); }
  .home-redes__h {
    font-family: var(--alt-font-display); font-weight: var(--alt-fw-semibold);
    font-size: clamp(30px, 4vw, 48px); line-height: 1.04; letter-spacing: var(--alt-tracking-tight);
    color: var(--alt-ink); margin: var(--alt-space-3) 0 20px;
  }
  .home-redes__handle {
    display: inline-flex; align-items: center; gap: 9px;
    background: var(--alt-grad-gold); color: var(--alt-ink);
    padding: 11px 22px; border-radius: var(--alt-r-pill);
    font-weight: var(--alt-fw-bold); font-size: 14px; text-decoration: none;
