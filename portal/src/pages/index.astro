    <!-- REDES — muro tipo Instagram (réplica fiel del mockup #redes, L1353-1398) -->
    <!-- El mockup pone el handle "@altorra.co" con href="#": NO es el real. Aquí va
         @altorrainmobiliaria + el enlace de SITE (§32.2: rutas reales ≠ placeholders). -->
    <section id="redes" class="home-band home-band--alt home-redes">
      <div class="alt-container">
        <div class="home-redes__head">
          <p class="alt-eyebrow">Síguenos en redes</p>
