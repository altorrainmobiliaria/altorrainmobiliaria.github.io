  .home-arr__pill:hover { color: var(--alt-ink); }
  .home-arr__pill.is-on { box-shadow: var(--alt-nm-in-sm); color: var(--alt-link); font-weight: var(--alt-fw-bold); }

  .home-arr__stack { display: flex; flex-direction: column; gap: clamp(14px, 1.6vw, 18px); }

  .home-arr__row {
