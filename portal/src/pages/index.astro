    <!-- JOURNAL -->
    <section id="journal" class="home-band">
      <div class="alt-container">
        <div class="home-sechead">
          <div>
            <p class="alt-eyebrow">El Journal</p>
            <h2>Ideas, guías y mercado.</h2>
          </div>
          <a class="alt-link-ul" href="/journal">Ver todo el Journal</a>
