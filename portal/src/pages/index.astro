</style>

<script>
  // Cambio de pestaña del buscador → actualiza pill activo, placeholder y destino.
  const tabsEl = document.querySelector('.home-search__tabs');
  const input = document.getElementById('home-hero-field') as HTMLInputElement | null;
  const form = document.querySelector('.home-search__row') as HTMLFormElement | null;
  tabsEl?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.home-search__tab') as HTMLElement | null;
    if (!btn) return;
    tabsEl.querySelectorAll('.home-search__tab').forEach((b) => b.setAttribute('aria-selected', 'false'));
    btn.setAttribute('aria-selected', 'true');
    if (input && btn.dataset.ph) input.placeholder = btn.dataset.ph;
    if (form && btn.dataset.tab) form.setAttribute('action', '/' + btn.dataset.tab);
  });

  // Hero carrusel — auto-advance inteligente (dwell por longitud de texto), sin flechas.
  const track = document.querySelector('[data-carousel]');
  if (track) {
    const banners = Array.from(track.querySelectorAll<HTMLElement>('.hbn'));
    const segs = Array.from(track.querySelectorAll<HTMLElement>('.hseg'));
    let idx = 0;
    let timer: ReturnType<typeof setTimeout> | undefined;
    const dwellFor = (b: HTMLElement) => {
      const h = b.querySelector('.hbn__h');
      const p = b.querySelector('.hbn__p');
      const txt = ((h?.textContent || '') + ' ' + (p?.textContent || '')).trim();
      const words = txt ? txt.split(/\s+/).length : 8;
      const extras = b.querySelectorAll('.hbn__step, .hbn__stats > div').length;
      return Math.max(4200, Math.min(2600 + words * 235 + extras * 480, 11500));
    };
    const paint = (dwell: number) => {
      segs.forEach((s, k) => {
        s.setAttribute('data-on', k === idx ? '1' : '0');
        const fl = s.querySelector<HTMLElement>('.hsegfill');
        if (fl) { fl.style.transition = 'none'; fl.style.width = k < idx ? '100%' : '0%'; }
      });
      const af = segs[idx]?.querySelector<HTMLElement>('.hsegfill');
      if (af) { void af.offsetWidth; af.style.transition = 'width ' + dwell + 'ms linear'; af.style.width = '100%'; }
    };
    const show = (n: number) => {
      idx = (n + banners.length) % banners.length;
      banners.forEach((b, k) => b.setAttribute('data-active', k === idx ? '1' : '0'));
      const dwell = dwellFor(banners[idx]);
      paint(dwell);
      clearTimeout(timer);
      timer = setTimeout(() => show(idx + 1), dwell);
    };
    segs.forEach((s, k) => {
      s.addEventListener('click', () => show(k));
      s.addEventListener('keydown', (e) => {
        const key = (e as KeyboardEvent).key;
        if (key === 'Enter' || key === ' ') { e.preventDefault(); show(k); }
      });
    });
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      banners.forEach((b, k) => b.setAttribute('data-active', k === 0 ? '1' : '0'));
    } else {
      show(0);
    }
  }

  // RIELES (`.alt-rail`) — genérico: sirve a los 4 carruseles de la home (venta/estancias/
  // valoradas/proyectos, ADR §32.9). Sin JS el riel ya funciona (swipe + scroll-snap nativo);
  // los botones son mejora progresiva y se apagan en los extremos.
  document.querySelectorAll<HTMLElement>('[data-railwrap]').forEach((wrap) => {
    const rail = wrap.querySelector<HTMLElement>('.alt-rail');
    if (!rail) return;
    const btns = Array.from(wrap.querySelectorAll<HTMLButtonElement>('.alt-rnav'));
    if (!btns.length) return;
    const step = () => Math.min(rail.clientWidth * 0.82, 560);
    const sync = () => {
      const max = rail.scrollWidth - rail.clientWidth - 1;
      btns.forEach((b) => {
        const atEdge = b.dataset.rail === 'prev' ? rail.scrollLeft <= 1 : rail.scrollLeft >= max;
        b.toggleAttribute('disabled', atEdge);
      });
    };
    const suave = () => (window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth') as ScrollBehavior;
    btns.forEach((b) => b.addEventListener('click', () => {
      rail.scrollBy({ left: (b.dataset.rail === 'prev' ? -1 : 1) * step(), behavior: suave() });
    }));
    rail.addEventListener('scroll', sync, { passive: true });
    window.addEventListener('resize', sync, { passive: true });
    sync();
  });

  // Favoritos de las LuCard — delegado (aún sin persistencia: la capa de datos llega con Firestore).
  document.addEventListener('click', (e) => {
    const fav = (e.target as HTMLElement).closest('.alt-lucard__fav') as HTMLElement | null;
    if (!fav) return;
    fav.setAttribute('aria-pressed', fav.getAttribute('aria-pressed') === 'true' ? 'false' : 'true');
  });

  // ARRIENDO — filtro con/sin administración: muestra/oculta filas por data-admin.
  const arrFilter = document.querySelector('.home-arr__filter');
  if (arrFilter) {
    const arrPills = Array.from(arrFilter.querySelectorAll<HTMLElement>('.home-arr__pill'));
    const arrRows = Array.from(document.querySelectorAll<HTMLElement>('#arriendo-stack .home-arr__row'));
    const arrEmpty = document.getElementById('arriendo-empty');
    arrFilter.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.home-arr__pill') as HTMLElement | null;
      if (!btn) return;
      const val = btn.dataset.val || 'todos';
      arrPills.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('is-on', on);
        b.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
      let visible = 0;
      arrRows.forEach((row) => {
        const show = val === 'todos' || row.dataset.admin === val;
        row.hidden = !show;
        if (show) visible++;
      });
      if (arrEmpty) arrEmpty.hidden = visible !== 0;
    });
  }
</script>
