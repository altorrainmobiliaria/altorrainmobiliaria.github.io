---
// HOME (Ola 1) — réplica del mockup ALTORRA Portal.dc.html sobre el design system D1.
// PÁGINA ESTÁTICA (prerenderizada) — declaración EXPLÍCITA (output:'server' => on-demand por defecto).
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PropertyCard from '../components/PropertyCard.astro';
import LuCard from '../components/LuCard.astro';
import StayCard from '../components/StayCard.astro';
import { SITE } from '../lib/config/site';

// CORTA ESTANCIA — riel de `StayCard` (réplica fiel del mockup #estancias-list, L760-835).
// Card `.bnb` del mockup: SIN caja, foto desnuda + texto suelto. NO es LuCard (§32.11).
const estancias = [
  { img: '/assets/hero-estancia.webp', alt: 'Terraza con piscina frente al mar', badge: 'Favorito entre huéspedes', title: 'Penthouse en Bocagrande', rating: '4.98', meta: 'Vista al mar · 6 huéspedes', price: '$680.000', href: '/estancias' },
  { img: '/assets/chalet-dusk.webp', alt: 'Casa colonial con patio', badge: 'Favorito entre huéspedes', title: 'Casa colonial en el Centro', rating: '4.91', meta: 'Patio y piscina · 8 huéspedes', price: '$1.150.000', href: '/estancias' },
  { img: '/assets/villa-pool.webp', alt: 'Apartamento frente a la playa en El Laguito', title: 'Apartamento en El Laguito', rating: '4.86', meta: 'Frente a la playa · 4 huéspedes', price: '$420.000', href: '/estancias' },
  { img: '/assets/villa-modern.webp', alt: 'Loft de autor en Getsemaní', badge: 'Favorito entre huéspedes', title: 'Loft de autor en Getsemaní', rating: '5.0', meta: 'Diseño · 2 huéspedes', price: '$390.000', href: '/estancias' },
  { img: '/assets/estate-golden.webp', alt: 'Villa con jardín privado en Manga', title: 'Villa con piscina en Manga', rating: '4.94', meta: 'Jardín privado · 10 huéspedes', price: '$1.480.000', href: '/estancias' },
];

// EN VENTA — riel horizontal de `LuCard` (réplica fiel del mockup #venta, L451-564).
// Swatches en tokens de paleta (el mockup traía #8a6d1f/#c7d3dd ajenos → §3.2 disciplina estricta).
const venta = [
  { img: '/assets/villa-pool.webp', alt: 'Apartamento en Castillogrande', imgPos: 'center 60%', badge: 'En venta', zona: 'Castillogrande', title: 'Torre Marea', tagline: 'Vista abierta a la bahía.', swatches: ['navy', 'gold', 'silver'], tipologias: '3 tipologías', specs: ['3 hab.', '3 baños', '142 m²'], price: 'Desde $1.450M', note: 'o crédito desde $6.2M/mes', href: '/ficha' },
  { img: '/assets/villa-modern.webp', alt: 'Casa republicana en Manga', badge: 'En venta', zona: 'Manga', title: 'Casa Republicana', tagline: 'Patrimonio restaurado con alma.', swatches: ['gold', 'navy'], tipologias: '2 tipologías', specs: ['4 hab.', '3 baños', '210 m²'], price: 'Desde $980M', note: 'o crédito desde $4.1M/mes', href: '/ficha' },
  { img: '/assets/estate-golden.webp', alt: 'Penthouse en Bocagrande', badge: 'En venta', zona: 'Bocagrande', title: 'Penthouse Dorado', tagline: 'Terraza privada con piscina.', swatches: ['gold-bright', 'gold', 'navy', 'silver'], tipologias: 'única', specs: ['4 hab.', '4 baños', '320 m²'], price: 'Desde $3.200M', note: 'o crédito desde $13.6M/mes', href: '/ficha' },
  { img: '/assets/hero-invierte.webp', alt: 'Proyecto sobre planos en el Centro Histórico', badge: 'Sobre planos', zona: 'Centro Histórico', title: 'Claustro 1620', tagline: 'Lofts dentro de la muralla.', swatches: ['navy', 'gold', 'silver'], tipologias: '4 tipologías', specs: ['1–2 hab.', '2 baños', '68 m²'], price: 'Desde $720M', note: 'entrega dic. 2026', href: '/ficha' },
  { img: '/assets/hero-keys.webp', alt: 'Casa colonial en Getsemaní', imgPos: 'center 40%', badge: 'En venta', zona: 'Getsemaní', title: 'Casa Trinidad', tagline: 'Colonial con patio interior.', swatches: ['gold', 'navy'], tipologias: '2 tipologías', specs: ['3 hab.', '2 baños', '128 m²'], price: 'Desde $1.180M', note: 'o crédito desde $5M/mes', href: '/ficha' },
];

// Datos DEMO (estáticos) — la conexión a Firestore real llega cuando haya inventario
// (decisión SSG vs doc-índice DIFERIDA a Fable, TODO-22). Imágenes = placeholders del diseño.
const destacadas = [
  { img: '/assets/villa-pool.webp', alt: 'Apartamento con vista a la bahía', badge: 'En venta', zona: 'Castillogrande', beds: 3, baths: 3, area: '142 m²', title: 'Apartamento con vista a la bahía', price: '$1.450.000.000', priceLabel: 'Desde', href: '/comprar' },
  { img: '/assets/villa-modern.webp', alt: 'Casa republicana restaurada', badge: 'En venta', zona: 'Manga', beds: 4, baths: 3, area: '210 m²', title: 'Casa republicana restaurada', price: '$980.000.000', priceLabel: 'Desde', href: '/comprar' },
  { img: '/assets/estate-golden.webp', alt: 'Penthouse frente al mar', badge: 'En venta', zona: 'Bocagrande', beds: 3, baths: 4, area: '188 m²', title: 'Penthouse frente al mar', price: '$2.100.000.000', priceLabel: 'Desde', href: '/comprar' },
];

// ARRIENDO — lista horizontal con filtro con/sin administración (réplica fiel del mockup #arriendo).
// Estructura RICA (specs, amenity, adminLabel, admin) — diseño PROPIO de la sección, NO PropertyCard.
const arriendo = [
  { img: '/assets/villa-modern.webp', alt: 'Apartamento amoblado en El Laguito', admin: 'con', photos: 14, zona: 'El Laguito, Bocagrande', title: 'Apartamento amoblado frente a la playa', specs: ['88 m²', '2 hab.', '2 baños', '1 garaje'], amenity: 'Amoblado', adminLabel: 'Administración incluida', price: '$4.200.000', href: '/arrendar' },
  { img: '/assets/hero-keys.webp', alt: 'Apartaestudio en Getsemaní', admin: 'sin', photos: 9, zona: 'Getsemaní', title: 'Apartaestudio de diseño en barrio histórico', specs: ['42 m²', '1 hab.', '1 baño'], amenity: 'Estrenar', adminLabel: 'No incluye administración', price: '$1.900.000', href: '/arrendar', imgPos: 'center 42%' },
  { img: '/assets/chalet-dusk.webp', alt: 'Casa familiar en Manga', admin: 'sin', photos: 21, zona: 'Manga', title: 'Casa familiar con jardín y estudio', specs: ['185 m²', '4 hab.', '3 baños', '2 garajes'], amenity: null, adminLabel: '+ administración $650.000', price: '$6.500.000', href: '/arrendar' },
  { img: '/assets/villa-pool.webp', alt: 'Apartamento en Castillogrande', admin: 'con', photos: 17, zona: 'Castillogrande', title: 'Apartamento con balcón y vista a la bahía', specs: ['120 m²', '3 hab.', '2 baños'], amenity: 'Vista mar', adminLabel: 'Administración incluida', price: '$5.100.000', href: '/arrendar' },
];

const cerca = [
  { img: '/assets/estate-golden.webp', alt: 'Penthouse en Bocagrande', badge: 'En venta', zona: 'Bocagrande', beds: 3, baths: 3, area: '175 m²', title: 'Penthouse con terraza privada', price: '$1.780.000.000', priceLabel: 'Desde', href: '/comprar' },
  { img: '/assets/chalet-dusk.webp', alt: 'Casa en Castillogrande', badge: 'En venta', zona: 'Castillogrande', beds: 4, baths: 4, area: '260 m²', title: 'Casa con jardín en Castillogrande', price: '$3.400.000.000', priceLabel: 'Desde', href: '/comprar' },
  { img: '/assets/villa-modern.webp', alt: 'Apartamento en Manga', badge: 'En venta', zona: 'Manga', beds: 2, baths: 2, area: '98 m²', title: 'Apartamento moderno en Manga', price: '$620.000.000', priceLabel: 'Desde', href: '/comprar' },
];

// Journal — 1 destacado + 3 horizontales.
const journalMain = { img: '/assets/estate-golden.webp', cat: 'Mercado', date: '12 feb 2026', read: '8 min de lectura', title: 'Guía 2026: dónde comprar en Cartagena antes de la próxima ola de valorización', excerpt: 'Analizamos precio por m², proyección de obra nueva y liquidez zona por zona, para que tu compra sea patrimonio y no una apuesta.', href: '/journal' };
const journalSide = [
  { img: '/assets/villa-pool.webp', cat: 'Rentas', read: '5 min de lectura', title: 'Corta estancia: renta tu propiedad sin dolores de cabeza', href: '/journal' },
  { img: '/assets/villa-modern.webp', cat: 'Inversión', read: '6 min de lectura', title: 'Manga o Bocagrande: en cuál invertir según tu objetivo', href: '/journal' },
  { img: '/assets/chalet-dusk.webp', cat: 'Legal', read: '4 min de lectura', title: 'Checklist legal antes de firmar la promesa de compraventa', href: '/journal' },
];

const brokerPerks = [
  'Comisiones entre las más competitivas del mercado',
  'Leads calificados cada semana y CRM incluido',
  'Respaldo jurídico y de marca en cada operación',
];

// Pestañas del buscador del hero (buscar por operación).
const tabs = [
  { key: 'comprar', label: 'Comprar', ph: '¿En qué zona quieres comprar?' },
  { key: 'arrendar', label: 'Arrendar', ph: '¿En qué zona quieres arrendar?' },
  { key: 'estancias', label: 'Estancias', ph: '¿En qué zona te quieres alojar?' },
  { key: 'invertir', label: 'Invertir', ph: '¿En qué zona quieres invertir?' },
];

// "Cuatro maneras de vivir Cartagena".
const maneras = [
  { n: '01', t: 'Comprar', img: '/assets/villa-modern.webp', d: 'Tu hogar o tu próxima inversión, con acompañamiento legal de principio a fin.', href: '/comprar' },
  { n: '02', t: 'Arrendar', img: '/assets/chalet-dusk.webp', d: 'Contratos claros y estudios serios. Vive tranquilo, entrega tranquilo.', href: '/arrendar' },
  { n: '03', t: 'Invertir', img: '/assets/estate-golden.webp', d: 'Rentabilidad y valorización en la ciudad amurallada, con cifras sobre la mesa.', href: '/invertir' },
  { n: '04', t: 'Estancias', img: '/assets/villa-pool.webp', d: 'Alójate frente al mar o entre murallas, con la confianza de un anfitrión verificado.', href: '/estancias' },
];
---

<BaseLayout title={`${SITE.name} — ${SITE.slogan}`}>
  <Header active="inicio" />

  <main id="main">
    <!-- HERO — carrusel de 4 banners + buscador superpuesto (réplica ALTORRA Portal.dc.html) -->
    <section class="home-hero">
      <div class="home-hero__car" data-carousel>

        <!-- B0 · Vivienda -->
        <div class="hbn hbn--full" data-b="0" data-active="1" data-nav="light">
          <img class="hbn__img" src="/assets/hero-keys.webp" alt="Pareja recibiendo las llaves de su hogar en Cartagena" style="object-position:80% 24%" fetchpriority="high" />
          <span class="hbn__wash hbn__wash--x" aria-hidden="true"></span>
          <span class="hbn__wash hbn__wash--b" aria-hidden="true"></span>
          <div class="hbn__wrap">
            <div class="hbn__rise" style="max-width:640px">
              <h1 class="hbn__h">Cartagena <span class="hbn__gold">entera</span>, a la altura de tu decisión.</h1>
              <p class="hbn__p">Comprar, arrendar, invertir o alojarte por unos días — en cada zona de la ciudad, con el nivel que tu decisión merece.</p>
              <a href="/comprar" class="hbtn-sig">Explorar propiedades<span class="hbtn-sig__arw"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span></a>
              <div class="hbn__trust">
                <span>Seguridad</span><span class="hbn__tdot"></span>
                <span>Legalidad</span><span class="hbn__tdot"></span>
                <span>Confianza</span>
              </div>
            </div>
          </div>
        </div>

        <!-- B1 · Inversión -->
        <div class="hbn hbn--full" data-b="1" data-active="0" data-nav="light">
          <img class="hbn__img" src="/assets/hero-invierte.webp" alt="Desarrollo residencial frente al mar en Cartagena" style="object-position:center 54%" loading="lazy" />
          <div class="hbn__wrap">
            <div class="hbn__rise" style="max-width:520px">
              <div class="hbn__panel">
                <h1 class="hbn__h">Invierte donde la ciudad <span class="hbn__gold">crece</span>.</h1>
                <div class="hbn__stats">
                  <div><b>+12%</b><span>valorización anual</span></div>
                  <span class="hbn__statdiv" aria-hidden="true"></span>
                  <div><b>8–11%</b><span>ROI en USD</span></div>
                  <span class="hbn__statdiv" aria-hidden="true"></span>
                  <div><b>3</b><span>zonas premium</span></div>
                </div>
                <a href="/invertir" class="hbtn-goldflat">Ver oportunidades</a>
              </div>
            </div>
          </div>
        </div>

        <!-- B2 · Corta estancia -->
        <div class="hbn hbn--full" data-b="2" data-active="0" data-nav="light">
          <img class="hbn__img" src="/assets/hero-estancia.webp" alt="Terraza con piscina al atardecer sobre el mar Caribe, Cartagena" style="object-position:center 46%" loading="lazy" />
          <div class="hbn__wrap">
            <div class="hbn__rise" style="max-width:560px">
              <div class="hbn__glass alt-glass">
                <h1 class="hbn__h">Vive Cartagena por <span class="hbn__gold">unos días</span>.</h1>
                <div class="hbn__rate">
                  <span class="hbn__star"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.2 6.6.8-4.9 4.6 1.3 6.6L12 18.6 6.1 20.8l1.3-6.6L2.5 9l6.6-.8z"/></svg><b>4.97</b><small>· 128 reseñas</small></span>
                  <span class="hbn__tdot" aria-hidden="true"></span>
                  <span class="hbn__from">Desde <b>$420k</b> / noche</span>
                </div>
                <p class="hbn__p">Propiedades verificadas dentro de la ciudad amurallada, listas para habitar, con anfitrión que responde.</p>
                <a href="/estancias" class="hbtn-outline">Descubrir estancias</a>
              </div>
            </div>
          </div>
        </div>

        <!-- B3 · Propietarios (split) -->
        <div class="hbn hbn--split" data-b="3" data-active="0" data-nav="light">
          <div class="hbn__wrap">
            <div class="hbn__split hbn__rise">
              <div class="hbn__splitmedia"><div class="hbn__frame"><img src="/assets/villa-modern.webp" alt="Inmueble administrado por ALTORRA" loading="lazy" /></div></div>
              <div class="hbn__splittext">
                <h1 class="hbn__h">Tu inmueble en las <span class="hbn__gold">mejores manos</span>.</h1>
                <p class="hbn__p">Lo publicamos, lo mostramos y lo administramos con el estándar ALTORRA, de principio a fin.</p>
                <div class="hbn__steps">
                  <span class="hbn__step"><b>01</b>Publicamos</span>
                  <svg class="hbn__stepsep" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
                  <span class="hbn__step"><b>02</b>Mostramos</span>
                  <svg class="hbn__stepsep" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
                  <span class="hbn__step"><b>03</b>Administramos</span>
                </div>
                <a href="/publicar" class="hbtn-outline">Publicar mi inmueble</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Control: barra de progreso segmentada (auto, sin flechas) -->
        <div class="home-hero__nav">
          <div class="home-hero__navin">
            <div class="hseg-row">
              <span class="hseg" data-seg-i="0" data-on="1" role="button" tabindex="0" aria-label="Banner 1"><span class="hsegfill"></span></span>
              <span class="hseg" data-seg-i="1" role="button" tabindex="0" aria-label="Banner 2"><span class="hsegfill"></span></span>
              <span class="hseg" data-seg-i="2" role="button" tabindex="0" aria-label="Banner 3"><span class="hsegfill"></span></span>
              <span class="hseg" data-seg-i="3" role="button" tabindex="0" aria-label="Banner 4"><span class="hsegfill"></span></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Buscador segmentado neumórfico, superpuesto sobre el hero -->
      <div class="home-search">
        <div class="home-search__card" data-surface="neu">
          <div class="home-search__tabs" role="tablist" aria-label="Buscar por operación">
            {tabs.map((t, i) => (
              <button class="home-search__tab" role="tab" type="button" aria-selected={i === 0 ? 'true' : 'false'} data-ph={t.ph} data-tab={t.key}>{t.label}</button>
            ))}
          </div>
          <form class="home-search__row" action="/comprar" method="get" role="search">
            <div class="home-search__field">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11z"/><circle cx="12" cy="10" r="2.6"/></svg>
              <label>
                <span class="home-search__lbl">Zona</span>
                <input id="home-hero-field" name="zona" placeholder={tabs[0].ph} autocomplete="off" />
              </label>
            </div>
            <span class="home-search__vdiv" aria-hidden="true"></span>
            <div class="home-search__field home-search__field--type">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10.5 12 4l9 6.5"/><path d="M5 9.5V20h14V9.5"/><path d="M9.5 20v-6h5v6"/></svg>
              <label>
                <span class="home-search__lbl">Tipo</span>
                <select name="tipo">
                  <option value="">Todos</option>
                  <option>Apartamento</option>
                  <option>Casa</option>
                  <option>Penthouse</option>
                  <option>Local</option>
                  <option>Lote</option>
                  <option>Finca</option>
                </select>
              </label>
            </div>
            <button class="home-search__go" type="submit" aria-label="Buscar">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="21" y2="21"/></svg>
            </button>
          </form>
        </div>
      </div>
    </section>

    <!-- CUATRO MANERAS -->
    <section class="alt-section alt-container">
      <div class="home-maneras__head">
        <p class="alt-eyebrow">Cuatro maneras de vivir Cartagena</p>
        <h2>Una sola casa para cada decisión de vivienda.</h2>
      </div>
      <div class="home-maneras__grid">
        {maneras.map((m) => (
          <a class="home-manera" href={m.href}>
            <img src={m.img} alt={m.t} loading="lazy" decoding="async" />
            <span class="home-manera__scrim"></span>
            <span class="home-manera__body">
              <span class="home-manera__n">{m.n}</span>
              <span class="home-manera__t">{m.t}</span>
              <span class="home-manera__d">{m.d}</span>
              <span class="home-manera__cta">Explorar
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </span>
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- EN VENTA — riel horizontal (réplica fiel del mockup #venta) -->
    <!-- `data-railwrap` envuelve encabezado Y riel: en el mockup los botones viven en un
         [data-railwrap] hermano del riel → su querySelector('.arail') no encuentra nada y
         las flechas NO funcionan. Misma arquitectura, corregida (ADR §32.10). -->
    <section id="venta" class="home-band home-band--alt home-railsec">
      <div class="alt-container" data-railwrap>
        <div class="home-sechead">
          <div>
            <p class="alt-eyebrow">En venta</p>
            <h2>Explora el portafolio en venta.</h2>
          </div>
          <div class="home-railsec__tools">
            <a class="alt-link-ul" href="/comprar">Comparar todas
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="width:15px;height:15px"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
            <div class="home-railsec__navbtns">
              <button class="alt-rnav" type="button" data-rail="prev" aria-label="Ver propiedades anteriores">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
              </button>
              <button class="alt-rnav" type="button" data-rail="next" aria-label="Ver más propiedades">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
              </button>
            </div>
          </div>
        </div>

        <div class="alt-rail">
          {venta.map((p) => <LuCard {...p} />)}
          <a class="home-railcta" href="/comprar">
            <span class="home-railcta__n">128</span>
            <span class="home-railcta__d">propiedades en venta en toda la ciudad</span>
            <span class="alt-btn alt-btn--on-ink">Ver todas
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:15px;height:15px"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </a>
        </div>
      </div>
    </section>

    <!-- DESTACADAS -->
    <section id="destacadas" class="home-band">
      <div class="alt-container">
        <div class="home-sechead">
          <div>
            <p class="alt-eyebrow">Selección ALTORRA</p>
            <h2>Destacadas esta semana</h2>
          </div>
          <a class="home-seelink" href="/comprar">Ver todas <b>128</b>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
        <div class="home-pgrid">
          {destacadas.map((p) => <PropertyCard {...p} />)}
          <div class="home-ctacard alt-card--ink">
            <p class="home-ctacard__n">128 propiedades</p>
            <p class="home-ctacard__d">en venta, arriendo y corta estancia en toda Cartagena.</p>
            <a class="alt-btn alt-btn--on-ink" href="/comprar">Ver todas
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:15px;height:15px"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

