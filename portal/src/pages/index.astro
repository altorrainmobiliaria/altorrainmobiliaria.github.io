  .hbtn-outline:hover { background: var(--alt-grad-gold); color: var(--alt-ink); border-color: transparent; }

  /* B1 panel blanco */
  .hbn__panel { background: var(--alt-white); border-top: 3px solid var(--alt-gold); border-radius: 3px 3px 14px 14px; padding: clamp(22px, 2.4vw, 30px); box-shadow: 0 46px 100px -38px rgba(27, 39, 51, 0.5); }
