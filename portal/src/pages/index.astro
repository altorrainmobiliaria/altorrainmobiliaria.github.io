---

<BaseLayout title={`${SITE.name} — ${SITE.slogan}`}>
  <Header active="inicio" />

  <main id="main">
    <!-- HERO — carrusel de 4 banners + buscador superpuesto (réplica ALTORRA Portal.dc.html) -->
    <section class="home-hero">
      <div class="home-hero__car" data-carousel>

        <!-- B0 · Vivienda -->
        <div class="hbn hbn--full" data-b="0" data-active="1" data-nav="light">
          <img class="hbn__img" src="/assets/hero-keys.webp" alt="Pareja recibiendo las llaves de su hogar en Cartagena" style="object-position:80% 24%" fetchpriority="high" />
          <span class="hbn__wash hbn__wash--x" aria-hidden="true"></span>
          <span class="hbn__wash hbn__wash--b" aria-hidden="true"></span>
          <div class="hbn__wrap">
            <div class="hbn__rise" style="max-width:640px">
              <h1 class="hbn__h">Cartagena <span class="hbn__gold">entera</span>, a la altura de tu decisión.</h1>
              <p class="hbn__p">Comprar, arrendar, invertir o alojarte por unos días — en cada zona de la ciudad, con el nivel que tu decisión merece.</p>
              <a href="/comprar" class="hbtn-sig">Explorar propiedades<span class="hbtn-sig__arw"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span></a>
              <div class="hbn__trust">
                <span>Seguridad</span><span class="hbn__tdot"></span>
                <span>Legalidad</span><span class="hbn__tdot"></span>
                <span>Confianza</span>
              </div>
            </div>
          </div>
        </div>

        <!-- B1 · Inversión -->
        <div class="hbn hbn--full" data-b="1" data-active="0" data-nav="light">
          <img class="hbn__img" src="/assets/hero-invierte.webp" alt="Desarrollo residencial frente al mar en Cartagena" style="object-position:center 54%" loading="lazy" />
          <div class="hbn__wrap">
            <div class="hbn__rise" style="max-width:520px">
              <div class="hbn__panel">
                <h1 class="hbn__h">Invierte donde la ciudad <span class="hbn__gold">crece</span>.</h1>
                <div class="hbn__stats">
                  <div><b>+12%</b><span>valorización anual</span></div>
                  <span class="hbn__statdiv" aria-hidden="true"></span>
                  <div><b>8–11%</b><span>ROI en USD</span></div>
                  <span class="hbn__statdiv" aria-hidden="true"></span>
                  <div><b>3</b><span>zonas premium</span></div>
                </div>
                <a href="/invertir" class="hbtn-goldflat">Ver oportunidades</a>
              </div>
            </div>
          </div>
        </div>

        <!-- B2 · Corta estancia -->
        <div class="hbn hbn--full" data-b="2" data-active="0" data-nav="light">
          <img class="hbn__img" src="/assets/hero-estancia.webp" alt="Terraza con piscina al atardecer sobre el mar Caribe, Cartagena" style="object-position:center 46%" loading="lazy" />
          <div class="hbn__wrap">
            <div class="hbn__rise" style="max-width:560px">
              <div class="hbn__glass alt-glass">
                <h1 class="hbn__h">Vive Cartagena por <span class="hbn__gold">unos días</span>.</h1>
                <div class="hbn__rate">
                  <span class="hbn__star"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.2 6.6.8-4.9 4.6 1.3 6.6L12 18.6 6.1 20.8l1.3-6.6L2.5 9l6.6-.8z"/></svg><b>4.97</b><small>· 128 reseñas</small></span>
                  <span class="hbn__tdot" aria-hidden="true"></span>
                  <span class="hbn__from">Desde <b>$420k</b> / noche</span>
                </div>
                <p class="hbn__p">Propiedades verificadas dentro de la ciudad amurallada, listas para habitar, con anfitrión que responde.</p>
                <a href="/estancias" class="hbtn-outline">Descubrir estancias</a>
              </div>
            </div>
          </div>
        </div>

        <!-- B3 · Propietarios (split) -->
        <div class="hbn hbn--split" data-b="3" data-active="0" data-nav="light">
          <div class="hbn__wrap">
            <div class="hbn__split hbn__rise">
              <div class="hbn__splitmedia"><div class="hbn__frame"><img src="/assets/villa-modern.webp" alt="Inmueble administrado por ALTORRA" loading="lazy" /></div></div>
              <div class="hbn__splittext">
                <h1 class="hbn__h">Tu inmueble en las <span class="hbn__gold">mejores manos</span>.</h1>
                <p class="hbn__p">Lo publicamos, lo mostramos y lo administramos con el estándar ALTORRA, de principio a fin.</p>
                <div class="hbn__steps">
                  <span class="hbn__step"><b>01</b>Publicamos</span>
                  <svg class="hbn__stepsep" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
                  <span class="hbn__step"><b>02</b>Mostramos</span>
                  <svg class="hbn__stepsep" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
                  <span class="hbn__step"><b>03</b>Administramos</span>
                </div>
                <a href="/publicar" class="hbtn-outline">Publicar mi inmueble</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Control: barra de progreso segmentada (auto, sin flechas) -->
        <div class="home-hero__nav">
          <div class="home-hero__navin">
            <div class="hseg-row">
              <span class="hseg" data-seg-i="0" data-on="1" role="button" tabindex="0" aria-label="Banner 1"><span class="hsegfill"></span></span>
              <span class="hseg" data-seg-i="1" role="button" tabindex="0" aria-label="Banner 2"><span class="hsegfill"></span></span>
              <span class="hseg" data-seg-i="2" role="button" tabindex="0" aria-label="Banner 3"><span class="hsegfill"></span></span>
              <span class="hseg" data-seg-i="3" role="button" tabindex="0" aria-label="Banner 4"><span class="hsegfill"></span></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Buscador segmentado neumórfico, superpuesto sobre el hero -->
      <div class="home-search">
