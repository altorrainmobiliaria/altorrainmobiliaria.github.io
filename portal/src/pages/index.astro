<style>
  /* ===== HERO — carrusel de 4 banners + buscador superpuesto ===== */
  .home-hero { position: relative; background: var(--alt-surface-neu); padding-bottom: clamp(40px, 6vw, 72px); }
  .home-hero__car { position: relative; overflow: hidden; height: clamp(548px, 60vh, 580px); }

  .hbn { position: absolute; inset: 0; opacity: 0; pointer-events: none; transition: opacity 0.9s ease; background: #fff; }
  .hbn[data-active='1'] { opacity: 1; pointer-events: auto; }
  .hbn--split { background: var(--alt-surface-neu); }
  .hbn__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .hbn[data-active='1'] .hbn__img { animation: hkenburns 9s ease-out both; }
  @keyframes hkenburns { from { transform: scale(1); } to { transform: scale(1.12); } }

  .hbn__wash { position: absolute; inset: 0; pointer-events: none; }
  .hbn__wash--x { background: linear-gradient(92deg, rgba(255, 255, 255, 0.97) 0%, rgba(255, 255, 255, 0.9) 33%, rgba(255, 255, 255, 0.52) 56%, rgba(255, 255, 255, 0) 80%); }
  .hbn__wash--b { background: linear-gradient(0deg, rgba(255, 255, 255, 0.55) 0%, rgba(255, 255, 255, 0) 24%); }

  .hbn__wrap { position: relative; max-width: var(--alt-container); margin: 0 auto; height: 100%; padding: clamp(88px, 10vh, 104px) var(--alt-gutter) clamp(118px, 12vh, 136px); display: flex; align-items: center; }
  .hbn__rise > * { animation: hbnrise 0.85s var(--alt-ease) both; }
  .hbn[data-active='1'] .hbn__rise > *:nth-child(2) { animation-delay: 0.08s; }
  .hbn[data-active='1'] .hbn__rise > *:nth-child(3) { animation-delay: 0.16s; }
  .hbn[data-active='1'] .hbn__rise > *:nth-child(4) { animation-delay: 0.24s; }
  @keyframes hbnrise { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: none; } }
  @media (prefers-reduced-motion: reduce) { .hbn[data-active='1'] .hbn__img { animation: none; } .hbn__rise > * { animation: none !important; } }

  .hbn__h { font-family: var(--alt-font-display); font-weight: var(--alt-fw-bold); line-height: 1.03; letter-spacing: var(--alt-tracking-tight); color: var(--alt-ink); margin: 0 0 16px; font-size: clamp(32px, 4.4vw, 54px); text-wrap: balance; }
  .hbn__gold { color: var(--alt-link-lg); white-space: nowrap; }
  .hbn__p { font-size: clamp(15px, 1.4vw, 18px); line-height: 1.6; color: var(--alt-text); margin: 0 0 22px; max-width: 500px; }
  .hbn__trust { display: flex; align-items: center; gap: 11px; margin-top: 24px; flex-wrap: wrap; }
  .hbn__trust span:not(.hbn__tdot) { font-size: 10.5px; font-weight: var(--alt-fw-semibold); letter-spacing: 0.2em; text-transform: uppercase; color: var(--alt-text); }
  .hbn__tdot { width: 4px; height: 4px; border-radius: 50%; background: var(--alt-gold); }

  /* Botones del hero */
  .hbtn-sig { display: inline-flex; align-items: center; gap: 13px; padding: 14px 16px 14px 28px; border-radius: var(--alt-r-pill); background: var(--alt-grad-gold); color: var(--alt-ink); font-weight: var(--alt-fw-bold); font-size: 15px; text-decoration: none; box-shadow: var(--alt-nm-up), inset 0 1px 0 rgba(255, 255, 255, 0.55); transition: transform var(--alt-dur) var(--alt-ease), box-shadow var(--alt-dur) var(--alt-ease); }
  .hbtn-sig:hover { transform: translateY(-2px); }
  .hbtn-sig__arw { display: inline-flex; width: 30px; height: 30px; border-radius: 50%; background: rgba(6, 39, 67, 0.14); align-items: center; justify-content: center; flex: none; transition: background var(--alt-dur) var(--alt-ease); }
  .hbtn-sig__arw svg { width: 14px; height: 14px; stroke: var(--alt-ink); transition: transform var(--alt-dur) var(--alt-ease); }
  .hbtn-sig:hover .hbtn-sig__arw { background: var(--alt-ink); }
  .hbtn-sig:hover .hbtn-sig__arw svg { stroke: var(--alt-gold-bright); transform: translateX(3px); }
  .hbtn-goldflat { display: inline-flex; align-items: center; padding: 14px 30px; border-radius: var(--alt-r-pill); background: var(--alt-grad-gold); color: var(--alt-ink); font-weight: var(--alt-fw-bold); font-size: 14.5px; text-decoration: none; transition: transform var(--alt-dur) var(--alt-ease), box-shadow var(--alt-dur) var(--alt-ease); }
