---
/*
 * 404 — página no encontrada / sección en construcción (Ola 1).
 * Con Header/Footer compartidos para que las rutas de la nav aún no construidas
 * (estancias/invertir/publicar/turismo/aliados/gestion/journal…) no rompan la experiencia.
 */
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Página no encontrada — ALTORRA Inmobiliaria">
  <Header active="" />

  <main id="main" class="nf">
    <div class="alt-container nf__in">
      <p class="alt-eyebrow">Error 404</p>
      <h1 class="nf__h">Esta sección aún está en construcción.</h1>
      <p class="nf__p">La página que buscas no existe o todavía no la hemos abierto al público. Mientras tanto, explora nuestras propiedades o escríbenos y con gusto te ayudamos.</p>
      <hr class="alt-divider alt-divider--center nf__div" />
      <div class="nf__cta">
        <a class="alt-btn alt-btn--gold" href="/">Volver al inicio
          <span class="alt-btn__arw"><svg viewBox="0 0 24 24" fill="none" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </a>
        <a class="alt-btn alt-btn--outline" href="/comprar">Ver propiedades</a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .nf { display: grid; place-items: center; padding-block: clamp(64px, 12vw, 140px); background: var(--alt-surface-neu); }
  .nf__in { max-width: 600px; text-align: center; }
  .nf__h { font-size: var(--alt-fs-h1); margin-top: var(--alt-space-3); }
  .nf__p { margin-top: var(--alt-space-4); font-size: var(--alt-fs-lg); color: var(--alt-text); }
  .nf__div { margin: var(--alt-space-6) auto; }
  .nf__cta { display: flex; gap: var(--alt-space-4); justify-content: center; flex-wrap: wrap; }
</style>
