---
/*
 * FICHA de inmueble (Ola 1) — réplica de ALTORRA Ficha.dc.html. Demo estática (1 propiedad).
 * Reutiliza Header/Footer/PropertyCard. Sin gráficas (regla Daniel).
 * Mapa/POIs = esquemático (MapLibre real = follow-up). Contacto vía SITE.
 */
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PropertyCard from '../components/PropertyCard.astro';
import { SITE } from '../lib/config/site';

const gallery = ['/assets/villa-pool.webp', '/assets/villa-modern.webp', '/assets/estate-golden.webp', '/assets/villa-modern.webp'];

const specs = [
  { i: '<path d="M2 4v16"/><path d="M2 9h16a3 3 0 0 1 3 3v8"/><path d="M2 15h20"/><path d="M6 9V7a2 2 0 0 1 2-2h5a2 2 0 0 1 2 2v2"/>', v: '3', l: 'Habitaciones' },
  { i: '<path d="M5 12V6a2 2 0 0 1 2-2 2 2 0 0 1 2 2"/><path d="M4 12h16a1 1 0 0 1 1 1v2a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4v-2a1 1 0 0 1 1-1z"/><path d="M7 19l-1 2M18 19l1 2"/>', v: '3', l: 'Baños' },
  { i: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 3v18"/>', v: '142 m²', l: 'Construidos' },
  { i: '<path d="M5 13l1.6-4.8A2 2 0 0 1 8.5 7h7a2 2 0 0 1 1.9 1.2L19 13"/><path d="M4 13h16a1 1 0 0 1 1 1v4H3v-4a1 1 0 0 1 1-1z"/><circle cx="7.5" cy="18" r="1.4"/><circle cx="16.5" cy="18" r="1.4"/>', v: '2', l: 'Parqueaderos' },
  { i: '<path d="M12 2 2 7l10 5 10-5-10-5z"/><path d="M2 12l10 5 10-5"/><path d="M2 17l10 5 10-5"/>', v: '6', l: 'Estrato' },
  { i: '<rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 10h18M8 2v4M16 2v4"/>', v: '2021', l: 'Construcción' },
];

const amenities = [
  { i: '<path d="M2 15c2 0 2 1.6 4 1.6s2-1.6 4-1.6 2 1.6 4 1.6 2-1.6 4-1.6 2 1.6 4 1.6"/><path d="M2 19c2 0 2 1.6 4 1.6s2-1.6 4-1.6 2 1.6 4 1.6 2-1.6 4-1.6 2 1.6 4 1.6"/><path d="M9 11V5a2 2 0 0 1 4 0"/>', t: 'Piscina infinita' },
  { i: '<path d="M12 3l7 3v6c0 4.2-3 7.4-7 8.4-4-1-7-4.2-7-8.4V6z"/><path d="M9 12l2 2 4-4"/>', t: 'Seguridad 24 h' },
  { i: '<path d="M6 8v8M18 8v8M4 10v4M20 10v4M6 12h12"/>', t: 'Gimnasio' },
  { i: '<circle cx="12" cy="7" r="3"/><path d="M3 17h18M5 17v-2M19 17v-2M12 10v7"/>', t: 'Vista al mar' },
  { i: '<rect x="6" y="3" width="12" height="18" rx="1.5"/><path d="M12 7l-2 2h4zM12 17l-2-2h4z"/>', t: 'Ascensor privado' },
  { i: '<path d="M4 8h9a2.5 2.5 0 1 0-2.5-2.5M4 12h13a2.5 2.5 0 1 1-2.5 2.5M4 16h8a2.5 2.5 0 1 1-2.5 2.5"/>', t: 'Aire acondicionado' },
  { i: '<path d="M4 10h16M6 10v8M10 10v8M14 10v8M18 10v8M3 18h18M6 10l6-4 6 4"/>', t: 'Balcón corrido' },
  { i: '<path d="M3 21V5a2 2 0 0 1 2-2h5v18M14 21V9h5a1 1 0 0 1 1 1v11M3 21h18"/><path d="M6 7h1M6 11h1M6 15h1"/>', t: 'Muelle privado' },
];

const tecnica = [['Tipo', 'Apartamento'], ['Piso', '8 de 12'], ['Área privada', '142 m²'], ['Administración', '$1.200.000 / mes'], ['Estrato', '6'], ['Estado', 'Entrega inmediata']];

const pois = [
  { i: '<path d="M2 15c2 0 2 1.4 4 1.4s2-1.4 4-1.4 2 1.4 4 1.4 2-1.4 4-1.4 2 1.4 4 1.4"/><path d="M2 19c2 0 2 1.4 4 1.4s2-1.4 4-1.4 2 1.4 4 1.4 2-1.4 4-1.4 2 1.4 4 1.4"/>', t: 'Malecón & Bahía', min: '2 min' },
  { i: '<circle cx="12" cy="5" r="2"/><path d="M12 7v13M5 13a7 7 0 0 0 14 0M3 13h2M19 13h2"/>', t: 'Club Naval', min: '4 min' },
  { i: '<path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/>', t: 'C.C. Bocagrande', min: '6 min' },
  { i: '<path d="M22 10 12 5 2 10l10 5 10-5z"/><path d="M6 12v5c0 1 2.7 3 6 3s6-2 6-3v-5"/>', t: 'Colegio Británico', min: '8 min' },
  { i: '<path d="M3 21h18M5 21V10M19 21V10M4 10 12 4l8 6z"/><path d="M9 21v-6h6v6"/>', t: 'Ciudad Amurallada', min: '9 min' },
  { i: '<path d="M17.8 19.2 16 11l3.5-3.5a2.1 2.1 0 0 0-3-3L13 8 4.8 6.2a.5.5 0 0 0-.5.8l3.4 3.4-2.3 2.3-1.9-.5-.9.9 2.6 1.9L9 20.6l.9-.9-.5-1.9 2.3-2.3 3.4 3.4a.5.5 0 0 0 .8-.5z"/>', t: 'Aeropuerto Rafael Núñez', min: '15 min' },
];

const similares = [
  { img: '/assets/villa-modern.webp', alt: 'Casa republicana restaurada', zona: 'Manga', beds: 4, baths: 3, area: '210 m²', title: 'Casa republicana restaurada', price: '$980.000.000', href: '/ficha' },
  { img: '/assets/estate-golden.webp', alt: 'Penthouse frente al mar', zona: 'Bocagrande', beds: 4, baths: 4, area: '260 m²', title: 'Penthouse frente al mar', price: '$2.100.000.000', href: '/ficha' },
  { img: '/assets/villa-pool.webp', alt: 'Casa familiar cerca del mar', zona: 'Crespo', beds: 3, baths: 2, area: '120 m²', title: 'Casa familiar cerca del mar', price: '$760.000.000', href: '/ficha' },
];

const waMsg = encodeURIComponent('Hola ALTORRA, me interesa el Apartamento con vista a la bahía en Castillogrande.');
---

<BaseLayout title="Apartamento con vista a la bahía, Castillogrande — ALTORRA">
  <Header active="" />

  <main id="main">
    <!-- Breadcrumb -->
    <nav class="ficha-bc" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span>/</span>
      <a href="/comprar">Comprar</a><span>/</span>
      <a href="/comprar">Castillogrande</a><span>/</span>
      <span class="ficha-bc__cur">Apartamento con vista a la bahía</span>
    </nav>

    <!-- Galería -->
    <div class="ficha-gal-wrap">
      <div class="ficha-gal">
        <div class="ficha-gal__main">
          <img id="ficha-main" src={gallery[0]} alt="Vista principal" />
          <span class="alt-badge ficha-gal__badge">En venta</span>
        </div>
        <div class="ficha-gal__cell"><img src={gallery[1]} alt="Interior" loading="lazy" /></div>
        <div class="ficha-gal__cell">
          <img src={gallery[2]} alt="Fachada" loading="lazy" />
          <a class="ficha-gal__more" href="#galeria"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>Ver 24 fotos</a>
        </div>
      </div>
      <div id="galeria" class="ficha-thumbs">
        {gallery.map((g, i) => <button class={`ficha-thumb${i === 0 ? ' is-on' : ''}`} type="button" data-src={g}><img src={g} alt={`Foto ${i + 1}`} loading="lazy" /></button>)}
        <span class="ficha-thumb ficha-thumb--more">+20</span>
      </div>
    </div>

    <!-- Info + aside -->
    <div class="ficha-body">
      <div class="ficha-main-col">
        <div class="ficha-title">
          <div>
            <p class="alt-eyebrow">Castillogrande</p>
            <h1 class="ficha-h1">Apartamento con vista a la bahía</h1>
            <p class="ficha-addr">Carrera 5 · Castillogrande, Cartagena de Indias</p>
          </div>
          <div class="ficha-actions">
            <button class="ficha-iconbtn ficha-fav" type="button" aria-label="Guardar en favoritos" aria-pressed="false"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 1 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/></svg></button>
            <button class="ficha-iconbtn" type="button" aria-label="Compartir"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.6 13.5l6.8 4M15.4 6.5l-6.8 4"/></svg></button>
          </div>
        </div>

        <div class="ficha-specs">
          {specs.map((s) => (
            <div class="ficha-spec">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={s.i}></svg>
              <span class="ficha-spec__v">{s.v}</span>
              <span class="ficha-spec__l">{s.l}</span>
            </div>
          ))}
        </div>

        <div class="ficha-sec ficha-sec--first">
          <h2>Sobre esta propiedad</h2>
          <p>Apartamento de 142 m² en uno de los edificios más exclusivos de Castillogrande, con vista frontal a la Bahía de Cartagena. Sala y comedor de doble altura, cocina integral tipo isla y un balcón corrido que recorre todo el frente marino.</p>
          <p>Tres alcobas con baño privado, alcoba principal con vestier y jacuzzi. El edificio cuenta con acceso controlado 24 horas, muelle privado, gimnasio y piscina infinita sobre la bahía. Entrega inmediata con acabados de lujo.</p>
        </div>
      </div>

      <aside class="ficha-aside">
        <div class="ficha-price">
          <p class="ficha-price__lbl">Precio de venta</p>
          <p class="ficha-price__val">$1.450.000.000</p>
          <p class="ficha-price__sub">$10.211.000 / m² · Administración $1.2M</p>
          <a class="alt-btn alt-btn--navy ficha-price__cta" href={`${SITE.contact.whatsappLink}?text=${waMsg}`}>Agendar visita<span class="alt-btn__arw"><svg viewBox="0 0 24 24" fill="none" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span></a>
          <a class="ficha-price__alt" href={`mailto:${SITE.contact.email}`}>Solicitar información</a>
          <div class="ficha-advisor">
            <span class="ficha-advisor__ini">MR</span>
            <div class="ficha-advisor__info">
              <span class="ficha-advisor__name">María Restrepo</span>
              <span class="ficha-advisor__role">Asesora ALTORRA · Zona Norte</span>
            </div>
            <a class="ficha-advisor__wa" href={SITE.contact.whatsappLink} aria-label="Contactar por WhatsApp"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.2a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2z"/></svg></a>
          </div>
        </div>

        <div class="ficha-fin">
          <p class="alt-eyebrow">Financiación</p>
          <p class="ficha-fin__val">Desde $7.9M / mes</p>
          <p class="ficha-fin__sub">Crédito hipotecario a 20 años · cuota inicial 30%</p>
          <a class="alt-link-ul ficha-fin__link" href="/comprar">Simular mi crédito<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        </div>
      </aside>
    </div>

    <!-- Secciones -->
    <div class="ficha-secs">
      <section class="ficha-sec">
        <h2>Amenidades</h2>
        <div class="ficha-amenities">
          {amenities.map((a) => (
            <div class="ficha-amenity">
              <span class="alt-chip"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={a.i}></svg></span>
              {a.t}
            </div>
          ))}
        </div>
      </section>

      <section class="ficha-sec">
        <h2>Ficha técnica</h2>
        <div class="ficha-tec">
          {tecnica.map(([k, v]) => <div class="ficha-tec__row"><span>{k}</span><span>{v}</span></div>)}
        </div>
      </section>

      <section class="ficha-sec">
        <h2>Ubicación</h2>
        <div class="ficha-loc">
          <div class="ficha-locmap alt-map" role="region" aria-label="Ubicación en Castillogrande, Cartagena"
            data-alt-map
            data-markers={JSON.stringify([{ i: 0, lat: 10.393, lng: -75.560, label: 'Castillogrande' }])}
            data-center="-75.560,10.393" data-zoom="15" data-pin-class="alt-mappin alt-mappin--ficha">
            {/* Lienzo del mapa real (MapLibre); aparece al pintar el basemap. */}
            <div class="alt-map__canvas" data-map-canvas></div>
            {/* Esquemático SELLADO = fallback hasta que el .pmtiles exista en R2. */}
            <span class="ficha-locmap__grid" data-schematic></span>
            <span class="ficha-locmap__land" data-schematic></span>
            <span class="ficha-locmap__road" data-schematic></span>
            <span class="ficha-locmap__bay" data-schematic>Bahía de Cartagena</span>
            <span class="ficha-locmap__pin" data-schematic data-pin-idx="0">Castillogrande</span>
            <span class="ficha-locmap__note" data-schematic>ALTORRA · mapa esquemático</span>
          </div>
          <div class="ficha-poi">
            <p class="alt-eyebrow">Puntos de interés</p>
            {pois.map((p) => (
              <div class="ficha-poi__row">
                <span class="ficha-poi__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={p.i}></svg></span>
                <span class="ficha-poi__t">{p.t}</span>
                <span class="ficha-poi__min">{p.min}</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    </div>

    <!-- Banda de cierre: Propiedades similares (fuera de .ficha-secs) -->
    <section class="ficha-closer">
      <div class="ficha-closer__in">
        <h2>Propiedades similares</h2>
        <div class="ficha-similar">
          {similares.map((p) => <PropertyCard {...p} />)}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .ficha-bc { max-width: 1300px; margin-inline: auto; padding: 20px clamp(16px, 4vw, 48px) 0; display: flex; align-items: center; gap: 9px; font-size: 12.5px; color: var(--alt-text); flex-wrap: wrap; }
  .ficha-bc a { color: var(--alt-text); text-decoration: none; }
  .ficha-bc a:hover { color: var(--alt-link); }
  .ficha-bc span { color: var(--alt-track); }
  .ficha-bc__cur { color: var(--alt-ink); font-weight: var(--alt-fw-semibold); }

  /* Galería */
  .ficha-gal-wrap { max-width: 1300px; margin-inline: auto; padding: 18px clamp(16px, 4vw, 48px) 0; }
  .ficha-gal { display: grid; grid-template-columns: 1.6fr 1fr; grid-auto-rows: 1fr; gap: 12px; height: clamp(360px, 50vw, 540px); }
  .ficha-gal__main { position: relative; grid-row: span 2; border-radius: var(--alt-r-lg); overflow: hidden; }
  .ficha-gal__main img { width: 100%; height: 100%; object-fit: cover; }
  .ficha-gal__badge { position: absolute; left: 18px; top: 18px; }
  .ficha-gal__cell { position: relative; border-radius: var(--alt-r-lg); overflow: hidden; }
  .ficha-gal__cell img { width: 100%; height: 100%; object-fit: cover; }
  .ficha-gal__more { position: absolute; right: 16px; bottom: 16px; display: inline-flex; align-items: center; gap: 8px; background: rgba(255, 255, 255, 0.95); padding: 11px 18px; border-radius: var(--alt-r-sm); font-size: 13px; font-weight: var(--alt-fw-semibold); color: var(--alt-ink); text-decoration: none; box-shadow: 0 8px 22px -10px rgba(27, 39, 51, 0.45); }
  .ficha-gal__more svg { width: 16px; height: 16px; }
  .ficha-gal__more:hover { color: var(--alt-link); }
  .ficha-thumbs { display: flex; gap: 10px; margin-top: 12px; flex-wrap: wrap; }
  .ficha-thumb { width: 96px; height: 66px; border-radius: var(--alt-r-chip, 10px); overflow: hidden; cursor: pointer; padding: 0; border: 0; background: none; outline: 2px solid transparent; outline-offset: 1px; transition: outline-color var(--alt-dur) var(--alt-ease); }
  .ficha-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .ficha-thumb.is-on { outline-color: var(--alt-gold); }
  .ficha-thumb--more { display: flex; align-items: center; justify-content: center; background: var(--alt-mist); font-size: 12px; font-weight: var(--alt-fw-semibold); color: var(--alt-text); }

  /* Body */
  .ficha-body { max-width: 1300px; margin-inline: auto; padding: 34px clamp(16px, 4vw, 48px) 6px; display: flex; gap: clamp(28px, 3.4vw, 56px); flex-wrap: wrap; align-items: flex-start; }
  .ficha-main-col { flex: 1 1 540px; min-width: 300px; }
  .ficha-title { display: flex; justify-content: space-between; align-items: flex-start; gap: 20px; flex-wrap: wrap; padding-bottom: 26px; border-bottom: 1px solid var(--alt-hairline); }
  .ficha-h1 { margin: var(--alt-space-2) 0; font-size: clamp(30px, 4.2vw, 46px); line-height: 1.02; }
  .ficha-addr { font-size: 14.5px; color: var(--alt-text); }
  .ficha-actions { display: flex; gap: 10px; }
  .ficha-iconbtn { width: 44px; height: 44px; border-radius: var(--alt-r-sm); border: 1px solid var(--alt-hairline-2); background: var(--alt-white); color: var(--alt-link); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: border-color var(--alt-dur) var(--alt-ease), color var(--alt-dur) var(--alt-ease); }
  .ficha-iconbtn svg { width: 19px; height: 19px; }
  .ficha-iconbtn:hover { border-color: var(--alt-gold); color: var(--alt-link); }
  .ficha-fav[aria-pressed='true'] { background: var(--alt-ink); border-color: var(--alt-ink); color: var(--alt-gold-bright); }

  .ficha-specs { display: grid; grid-template-columns: repeat(auto-fit, minmax(96px, 1fr)); gap: 14px; padding: 26px 0; border-bottom: 1px solid var(--alt-hairline); }
  .ficha-spec { display: flex; flex-direction: column; gap: 8px; }
  .ficha-spec svg { width: 21px; height: 21px; stroke: var(--alt-gold-raw); }
  .ficha-spec__v { font-size: 17px; font-weight: var(--alt-fw-semibold); color: var(--alt-ink); }
  .ficha-spec__l { font-size: 11.5px; color: var(--alt-text); }

  .ficha-sec h2 { font-family: var(--alt-font-display); font-weight: var(--alt-fw-semibold); font-size: 28px; color: var(--alt-ink); letter-spacing: normal; margin-bottom: 18px; }
  .ficha-sec--first { padding: 30px 0 2px; }
  .ficha-sec--first h2 { font-size: 26px; margin-bottom: 14px; }
  .ficha-sec--first p { font-size: 15.5px; line-height: 1.72; color: var(--alt-text); margin-bottom: 14px; }

  /* Aside */
  .ficha-aside { flex: 1 1 320px; min-width: 290px; position: sticky; top: 92px; align-self: flex-start; display: flex; flex-direction: column; gap: 18px; }
  .ficha-price { background: var(--alt-white); border: 1px solid var(--alt-hairline); border-radius: var(--alt-r-lg); padding: 26px; box-shadow: var(--alt-elev-aside); }
  .ficha-price__lbl { font-size: 12px; font-weight: var(--alt-fw-semibold); letter-spacing: 0.14em; text-transform: uppercase; color: var(--alt-text); margin-bottom: 6px; }
  .ficha-price__val { font-family: var(--alt-font-display); font-weight: var(--alt-fw-semibold); font-size: 38px; line-height: 1; color: var(--alt-ink); margin-bottom: 4px; }
  .ficha-price__sub { font-size: 13px; color: var(--alt-text); margin-bottom: 22px; }
  .ficha-price__cta { width: 100%; }
  .ficha-price__alt { display: flex; align-items: center; justify-content: center; gap: 9px; width: 100%; margin-top: 10px; padding: 14px; border-radius: var(--alt-r-sm); background: var(--alt-white); border: 1px solid var(--alt-gold); color: var(--alt-link); font-weight: var(--alt-fw-semibold); font-size: 14.5px; text-decoration: none; transition: background var(--alt-dur) var(--alt-ease); }
  .ficha-price__alt:hover { background: var(--alt-mist); }
  .ficha-advisor { display: flex; align-items: center; gap: 13px; margin-top: 22px; padding-top: 22px; border-top: 1px solid var(--alt-hairline); }
  .ficha-advisor__ini { width: 52px; height: 52px; border-radius: 50%; background: var(--alt-ink); display: flex; align-items: center; justify-content: center; flex: none; font-family: var(--alt-font-display); font-weight: var(--alt-fw-semibold); font-size: 19px; color: var(--alt-gold-bright); }
