<script>
  // Galería: clic en miniatura cambia la imagen principal.
  const main = document.getElementById('ficha-main') as HTMLImageElement | null;
  document.querySelectorAll('.ficha-thumb[data-src]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const src = (btn as HTMLElement).dataset.src;
      if (main && src) main.src = src;
      document.querySelectorAll('.ficha-thumb').forEach((b) => b.classList.remove('is-on'));
      btn.classList.add('is-on');
    });
  });

  // Favorito del encabezado: alterna estado on/off (navy + oro), como el toggleFav del mockup.
  const fav = document.querySelector('.ficha-fav');
  fav?.addEventListener('click', () => {
    const on = fav.getAttribute('aria-pressed') === 'true';
    fav.setAttribute('aria-pressed', on ? 'false' : 'true');
  });

  // Mapa real (MapLibre + Protomaps, TODO-30): monta sobre el esquemático y lo reemplaza al pintar.
  import('../scripts/altorra-map').then((m) => m.bootMaps());
</script>
