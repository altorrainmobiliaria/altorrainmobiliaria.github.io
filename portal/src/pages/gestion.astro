  .gx-cli__name { font-size: 13.5px; font-weight: var(--alt-fw-semibold); color: var(--alt-ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .gx-muted { font-size: 13px; color: var(--alt-text); }
  .gx-ell { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
