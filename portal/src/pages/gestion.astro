  .gx-pill { display: inline-flex; align-items: center; padding: 5px 11px; border-radius: var(--alt-r-pill); font-size: 11.5px; font-weight: var(--alt-fw-semibold); background: var(--alt-mist); }
  .gx-pill--gold { color: var(--alt-link); }
  .gx-pill--navy { color: var(--alt-ink); }

  /* ---- Actividad ---- */
  .gx-act-set { display: flex; flex-direction: column; gap: 16px; }
  .gx-act-set[hidden] { display: none; }
  .gx-act { display: flex; gap: 13px; }
  .gx-dot { width: 9px; height: 9px; border-radius: 50%; flex: none; margin-top: 5px; }
  .gx-dot--gold { background: var(--alt-gold-raw); }
  .gx-dot--navy { background: var(--alt-ink); }
  .gx-act__txt { font-size: 13.5px; font-weight: var(--alt-fw-semibold); color: var(--alt-ink); line-height: 1.35; }
  .gx-act__time { font-size: 12px; color: var(--alt-text-muted); margin-top: 2px; }

  /* ---- Demanda ---- */
  .gx-dem { display: flex; flex-direction: column; gap: 14px; }
