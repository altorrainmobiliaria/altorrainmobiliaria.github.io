  @media (prefers-reduced-motion: reduce) { .gx-kpi { animation: none; } }

  @media (max-width: 860px) {
    .gx-side { flex-basis: 100%; height: auto; position: static; flex-direction: row; align-items: center; flex-wrap: wrap; gap: 10px; padding: 14px 18px; }
