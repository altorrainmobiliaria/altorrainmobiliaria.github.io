  }
</style>

<script>
  // Segmentado de 3 roles: alterna las vistas [data-set] (ya renderizadas) + textos (textContent).
  // Sin innerHTML: los strings van por textContent y los bloques se muestran/ocultan con `hidden`.
  type Str = { user: string; userRole: string; avatar: string; greeting: string; subtitle: string; tableTitle: string };
  const STR: Record<string, Str> = JSON.parse(document.getElementById('gx-strings')!.textContent || '{}');
  const set = (id: string, txt: string) => { const e = document.getElementById(id); if (e) e.textContent = txt; };

  function show(role: string) {
    const s = STR[role];
    if (!s) return;
    set('gx-greeting', s.greeting);
    set('gx-subtitle', s.subtitle);
    set('gx-table-title', s.tableTitle);
    set('gx-user', s.user);
    set('gx-user-role', s.userRole);
    set('gx-avatar', s.avatar);
    document.querySelectorAll<HTMLElement>('[data-set]').forEach((el) => {
      el.hidden = el.dataset.set !== role;
    });
  }

  document.querySelectorAll<HTMLButtonElement>('.gx-seg__btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.gx-seg__btn').forEach((b) => {
        b.classList.remove('is-on');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('is-on');
      btn.setAttribute('aria-selected', 'true');
      show(btn.dataset.role || 'admin');
    });
  });
</script>
