---
// Design system D1 (carril D) — SSoT de tokens + primitivas. Réplica de los mockups
// aprobados (portal/design/mockups). El orden importa: tokens → base → components.
import '../styles/tokens.css';
import '../styles/base.css';
import '../styles/components.css';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Altorra Inmobiliaria — gestión integral en soluciones inmobiliarias. Cartagena de Indias.',
  noindex = false,
} = Astro.props;

// Indexable SOLO en build de producción; por defecto (staging *.workers.dev) => noindex (O3/T1).
// `noindex` fuerza noindex SIEMPRE (páginas internas/admin: /gestion, /design-system).
const indexable = import.meta.env.PUBLIC_SITE_ENV === 'production' && !noindex;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {!indexable && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/*
      Tipografía de marca (D1, DECIDIDA por Claude — Daniel delegó la fuente 2026-07-12):
      Cormorant Garamond (display) + Hanken Grotesk (cuerpo/UI). Coherente con los mockups,
      premium/editorial, distinta de Bersaglio (Fraunces+Manrope). Playfair NO se carga.
      TODO perf (SEO-first): migrar a self-host woff2 subset latin + preload de las 2 caras críticas
      (Cormorant 600, Hanken 400) para eliminar el handshake a fonts.gstatic.com y mejorar LCP.
    */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500;1,600&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
