---
/*
 * Header / navegación COMPARTIDA — REDISEÑO "barra de comando líquida flotante" (2026-07-12).
 * Fusión disciplinada de técnicas (cada una con su rol):
 *   · LIQUID GLASS  → la barra principal flota (backdrop-filter real + sheen + borde luminoso).
 *   · GLASSMORFISMO → los paneles desplegables (mega/rich) son vidrio esmerilado.
 *   · NEUMORFISMO   → controles blandos (favoritos, hamburguesa) extruidos que se hunden al presionar.
 *   · SKEUOMORFISMO → emblema metálico + CTA dorado "físico" (gradiente vertical + luz superior).
 * App-like: la barra se condensa al scrollear (la barra utilitaria se colapsa). Wordmark en TEXTO
 * vectorial (fin del pixelado del raster). Disciplina de color: solo paleta. Contacto/rutas REALES.
 * Props: active = clave del ítem de nav actual.
 */
import { SITE } from '../lib/config/site';

interface Props {
  active?: string;
}
const { active = '' } = Astro.props;

const icon = {
  pin: '<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="2.6"/>',
  phone: '<path d="M4 5c0 8.8 6.2 15 15 15l1.5-3.3-4.4-1.8-1.9 2a12 12 0 0 1-5.6-5.6l2-1.9L6.3 3.5 3 5z"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2.5"/><path d="m4 7 8 6 8-6"/>',
  caret: '<path d="M6 9l6 6 6-6"/>',
  heart: '<path d="M20.8 5.6a5.5 5.5 0 0 0-7.8 0L12 6.6l-1-1a5.5 5.5 0 1 0-7.8 7.8l1 1L12 21l7.8-7.8 1-1a5.5 5.5 0 0 0 0-7.6z"/>',
  user: '<circle cx="12" cy="8" r="3.4"/><path d="M5.5 20a6.5 6.5 0 0 1 13 0"/>',
  upload: '<path d="M3 11.4 12 4l9 7.4"/><path d="M5 9.8V20h14V9.8"/><path d="M10 20v-6h4v6"/>',
  burger: '<path d="M4 7h16"/><path d="M4 12h16"/><path d="M4 17h16"/>',
  close: '<path d="M6 6l12 12M18 6L6 18"/>',
  check: '<path d="M20 7 9 18l-5-5"/>',
  edit: '<path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/>',
  home: '<path d="M3 21V9l9-6 9 6v12"/><path d="M9 21v-6h6v6"/>',
  chart: '<path d="M4 19V5"/><path d="m4 15 5-5 4 4 7-8"/>',
  ig: '<rect x="3.5" y="3.5" width="17" height="17" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.4" cy="6.6" r="1.1" fill="currentColor" stroke="none"/>',
  fb: '<path d="M13.5 21v-7.5h2.5l.4-2.9h-2.9V8.7c0-.85.24-1.43 1.45-1.43h1.55V4.68c-.27-.04-1.2-.12-2.28-.12-2.26 0-3.8 1.38-3.8 3.9v2.18H8v2.9h2.42V21z" stroke="none" fill="currentColor"/>',
  wa: '<path d="M20 11.5a8 8 0 0 1-11.8 7L4 20l1.6-4A8 8 0 1 1 20 11.5z"/><path d="M9 9.5c0 3 2.5 5.5 5.5 5.5.6 0 1.2-.6 1.2-1.2l-1.7-1-.9.9c-1-.4-1.8-1.2-2.2-2.2l.9-.9-1-1.7C10.1 8.3 9.5 8.9 9 9.5z"/>',
};

const nav = [
  {
    key: 'comprar', label: 'Comprar', href: '/comprar', type: 'mega',
    cols: [
      { title: 'Por estado', links: [['Compra nuevo', '/comprar'], ['Compra usado', '/comprar']] },
      { title: 'Por tipo', links: [['Apartamentos', '/comprar'], ['Casas', '/comprar'], ['Penthouse', '/comprar'], ['Locales', '/comprar'], ['Lotes', '/comprar'], ['Fincas', '/comprar']] },
    ],
    featured: { img: '/assets/estate-golden.webp', eyebrow: 'Destacada', title: 'Penthouse en Bocagrande', href: '/comprar' },
  },
  {
    key: 'arrendar', label: 'Arrendar', href: '/arrendar', type: 'mega',
    cols: [
      { title: 'Por zona', links: [['Zona Norte', '/arrendar'], ['Centro Histórico', '/arrendar'], ['Bocagrande', '/arrendar'], ['Castillogrande', '/arrendar'], ['Manga', '/arrendar'], ['Getsemaní', '/arrendar']] },
      { title: 'Por tipo', links: [['Apartamentos', '/arrendar'], ['Casas', '/arrendar'], ['Penthouse', '/arrendar'], ['Locales', '/arrendar'], ['Fincas', '/arrendar']] },
    ],
  },
  {
    key: 'vender', label: 'Vender', href: '/publicar', type: 'rich', align: 'left',
    rich: [
      { icon: 'check', title: 'Lo vendemos por ti', sub: 'Avalúo, marketing y cierre, todo gestionado.', href: '/publicar' },
      { icon: 'edit', title: 'Véndelo tú mismo', sub: 'Publica y administra desde tu panel.', href: '/publicar' },
    ],
  },
  {
    key: 'estancia', label: 'Corta estancia', href: '/estancias', type: 'mega', align: 'right',
    cols: [
      { title: 'Experiencias', links: [['Frente al mar', '/estancias'], ['Zona Colonial', '/estancias'], ['Zona Amurallada', '/estancias'], ['Rooftop & Piscina', '/estancias'], ['Zona Campestre', '/estancias']] },
    ],
    featured: { img: '/assets/villa-pool.webp', eyebrow: 'Estancias premium', title: 'Terrazas frente a la bahía', href: '/estancias' },
  },
  {
    key: 'turismo', label: 'Turismo', href: '/turismo', type: 'rich', align: 'right',
    rich: [
      { icon: 'home', title: 'Turismo Inmobiliario', sub: 'Estadías, guías, fotografía y pasadías.', href: '/turismo' },
      { icon: 'chart', title: 'Asesoría de Inversión Turística', sub: 'Rentabilidad y compra con retorno.', href: '/turismo#inversion' },
    ],
    featured: { img: '/assets/villa-modern.webp', eyebrow: 'Cartagena te espera', title: 'Vive la ciudad amurallada', href: '/turismo' },
  },
  {
    key: 'servicios', label: 'Servicios', href: '#servicios', type: 'mega', align: 'right',
    cols: [
      { title: 'Gestión', links: [['Administración y Arriendo', '#servicios'], ['Compra & Venta', '#servicios'], ['Avalúos', '#servicios'], ['Gerencia de Proyectos', '#servicios']] },
      { title: 'Financiero & Marketing', links: [['Marketing Inmobiliario', '#servicios'], ['Crédito de Vivienda', '#servicios'], ['Pagos en Línea', '#servicios']] },
    ],
  },
  { key: 'nosotros', label: 'Nosotros', href: '#nosotros', type: 'link' },
  { key: 'contacto', label: 'Contacto', href: '#contacto', type: 'link' },
];
---

<header class="alt-hdr" data-hdr>
  <!-- Capa 1: barra utilitaria (vidrio fino, se colapsa al scrollear) -->
  <div class="alt-hdr__util">
    <div class="alt-hdr__util-in">
      <div class="alt-hdr__util-info">
        <span><svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={icon.pin}></svg>{SITE.city}</span>
        <a href={SITE.contact.whatsappLink}><svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={icon.phone}></svg>{SITE.contact.whatsapp}</a>
        <a href={`mailto:${SITE.contact.email}`}><svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={icon.mail}></svg>{SITE.contact.email}</a>
        <span class="alt-hdr__hours">Lun–Sáb · 8:00–18:00</span>
      </div>
      <div class="alt-hdr__soc">
        <a href={SITE.social.instagram} aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" set:html={icon.ig}></svg></a>
        <a href={SITE.social.facebook} aria-label="Facebook"><svg viewBox="0 0 24 24" fill="currentColor" stroke="none" set:html={icon.fb}></svg></a>
        <a href={SITE.contact.whatsappLink} aria-label="WhatsApp"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={icon.wa}></svg></a>
      </div>
    </div>
  </div>

  <!-- Capa 2: barra de comando líquida flotante -->
  <div class="alt-hdr__dock">
    <div class="alt-hdr__bar">
      <span class="alt-hdr__sheen" aria-hidden="true"></span>
      <div class="alt-hdr__bar-in">
        <a class="alt-hdr__logo" href="/" aria-label={`${SITE.name} — inicio`}>
          <span class="alt-hdr__mark"><img src="/assets/altorra-mark-t.webp" alt="" width="30" height="41" /></span>
          <span class="alt-hdr__word">
            <span class="alt-hdr__word-name">ALTORRA</span>
            <span class="alt-hdr__word-sub">Inmobiliaria</span>
          </span>
        </a>

        <nav class="alt-hdr__nav" aria-label="Principal">
          {nav.map((item) => (
            <div class={`alt-hdr__item${item.type !== 'link' ? ' has-mega' : ''}`}>
              <a class="alt-hdr__top" href={item.href} aria-current={active === item.key ? 'page' : undefined} data-active={active === item.key}>
                <span>
                  {item.label}
                  {item.type !== 'link' && <svg class="alt-hdr__cap" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" set:html={icon.caret} />}
                </span>
                <span class="alt-hdr__uline"></span>
              </a>

              {item.type !== 'link' && (
                <div class={`alt-hdr__pan align-${item.align || 'left'}`}>
                  <div class="alt-hdr__pan-card">
                    {item.type === 'mega' && item.cols?.map((col) => (
                      <div class="alt-hdr__col">
                        <p class="alt-eyebrow alt-hdr__col-h">{col.title}</p>
                        {col.links.map(([t, h]) => <a class="alt-hdr__lnk" href={h}>{t}</a>)}
                      </div>
                    ))}
                    {item.type === 'rich' && (
                      <div class="alt-hdr__rich">
                        {item.rich?.map((r) => (
                          <a class="alt-hdr__richlnk" href={r.href}>
                            <span class="alt-hdr__richicon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icon[r.icon]}></svg></span>
                            <span><span class="alt-hdr__richt">{r.title}</span><span class="alt-hdr__richs">{r.sub}</span></span>
                          </a>
                        ))}
                      </div>
                    )}
                    {item.featured && (
                      <a class="alt-hdr__feat" href={item.featured.href}>
                        <img src={item.featured.img} alt="" loading="lazy" decoding="async" />
                        <span class="alt-hdr__feat-body">
                          <span class="alt-hdr__feat-eb">{item.featured.eyebrow}</span>
                          <span class="alt-hdr__feat-t">{item.featured.title}</span>
                        </span>
                      </a>
                    )}
                  </div>
                </div>
              )}
            </div>
          ))}
        </nav>

        <div class="alt-hdr__actions">
          <a class="alt-hdr__fav" href="/favoritos" aria-label="Favoritos"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icon.heart}></svg></a>
          <a class="alt-hdr__login" href="/ingresar"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" set:html={icon.user}></svg><span>Ingresar</span></a>
          <a class="alt-hdr__pub" href="/publicar"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" set:html={icon.upload}></svg><span>Publica tu inmueble</span></a>
          <button class="alt-hdr__burger" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="alt-drawer" data-drawer-toggle>
            <svg class="alt-hdr__burger-o" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" set:html={icon.burger}></svg>
            <svg class="alt-hdr__burger-x" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" set:html={icon.close}></svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Capa 3: drawer móvil (vidrio) -->
  <div class="alt-hdr__drawer" id="alt-drawer" data-open="false">
    {nav.filter((n) => n.type !== 'link').map((item) => (
      <details class="alt-hdr__det">
        <summary>{item.label}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" set:html={icon.caret}></svg></summary>
        <div class="alt-hdr__det-links">
          {item.type === 'mega' && item.cols?.flatMap((c) => c.links).map(([t, h]) => <a href={h}>{t}</a>)}
          {item.type === 'rich' && item.rich?.map((r) => <a href={r.href}>{r.title}</a>)}
        </div>
      </details>
    ))}
    <a class="alt-hdr__det-flat" href="#nosotros">Nosotros</a>
    <a class="alt-hdr__det-flat" href="#contacto">Contacto</a>
    <div class="alt-hdr__drawer-cta">
      <a class="alt-hdr__pub" href="/publicar"><span>Publica tu inmueble</span></a>
      <a class="alt-hdr__login" href="/ingresar" style="justify-content:center"><span>Ingreso / Registro</span></a>
    </div>
  </div>
</header>

<style>
  /* ===== HEADER — barra de comando líquida flotante ===== */
  .alt-hdr { position: sticky; top: 0; z-index: var(--alt-z-header); background: transparent; }
  .alt-hdr svg { width: 100%; height: 100%; }

  /* Capa 1 · barra utilitaria (vidrio fino, colapsa al scrollear) */
  .alt-hdr__util {
    background: rgba(230, 237, 242, 0.7);
    -webkit-backdrop-filter: saturate(150%) blur(10px);
    backdrop-filter: saturate(150%) blur(10px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.5);
    overflow: hidden;
    max-height: 36px;
    transition: max-height 0.4s var(--alt-ease), opacity 0.3s var(--alt-ease), border-color 0.3s;
  }
  .alt-hdr.is-scrolled .alt-hdr__util { max-height: 0; opacity: 0; border-color: transparent; }
  .alt-hdr__util-in {
    max-width: var(--alt-container); margin-inline: auto; padding-inline: var(--alt-gutter);
    min-height: 36px; display: flex; align-items: center; justify-content: space-between; gap: var(--alt-space-5);
  }
  .alt-hdr__util-info { display: flex; align-items: center; gap: var(--alt-space-5); font-size: var(--alt-fs-xs); color: var(--alt-text); min-width: 0; }
  .alt-hdr__util-info span, .alt-hdr__util-info a { display: inline-flex; align-items: center; gap: 6px; white-space: nowrap; color: inherit; text-decoration: none; }
  .alt-hdr__util-info svg { width: 12px; height: 12px; stroke: var(--alt-gold-raw); flex: none; }
  .alt-hdr__util-info a:hover { color: var(--alt-link); }
  .alt-hdr__hours { color: var(--alt-text-muted); }
  .alt-hdr__soc { display: flex; align-items: center; gap: 14px; flex: none; }
  .alt-hdr__soc a { display: inline-flex; width: 15px; height: 15px; color: var(--alt-text); transition: color var(--alt-dur) var(--alt-ease), transform var(--alt-dur) var(--alt-ease); }
  .alt-hdr__soc a:hover { color: var(--alt-link); transform: translateY(-1px); }

  /* Capa 2 · dock que centra la barra flotante */
  .alt-hdr__dock { max-width: var(--alt-container); margin: 10px auto 0; padding-inline: clamp(12px, 3vw, 24px); transition: margin-top 0.35s var(--alt-ease); }
  .alt-hdr.is-scrolled .alt-hdr__dock { margin-top: 8px; }

  /* La barra: LIQUID GLASS (vidrio real + sheen + borde luminoso + sombra flotante) */
  .alt-hdr__bar {
    position: relative;
    border-radius: var(--alt-r-xl);
    background: rgba(255, 255, 255, 0.6);
    -webkit-backdrop-filter: saturate(180%) blur(22px);
    backdrop-filter: saturate(180%) blur(22px);
    border: 1px solid rgba(255, 255, 255, 0.65);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      inset 0 -10px 22px rgba(255, 255, 255, 0.28),
      0 22px 48px -26px rgba(6, 39, 67, 0.4),
      0 4px 14px -8px rgba(6, 39, 67, 0.14);
    transition: background 0.35s var(--alt-ease), box-shadow 0.35s var(--alt-ease);
  }
  @supports not ((-webkit-backdrop-filter: blur(1px)) or (backdrop-filter: blur(1px))) {
    .alt-hdr__bar { background: var(--alt-surface-neu); }
  }
  .alt-hdr.is-scrolled .alt-hdr__bar {
    background: rgba(255, 255, 255, 0.78);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.95),
      inset 0 -10px 22px rgba(255, 255, 255, 0.3),
      0 26px 56px -24px rgba(6, 39, 67, 0.46),
      0 6px 16px -8px rgba(6, 39, 67, 0.18);
  }
  /* Sheen superior: filo de luz dorada muy sutil (detalle premium) */
  .alt-hdr__sheen { position: absolute; left: 16%; right: 16%; top: 0; height: 1px; background: linear-gradient(90deg, transparent, rgba(235, 210, 126, 0.7), transparent); pointer-events: none; }

  .alt-hdr__bar-in {
    position: relative;
    padding-inline: clamp(14px, 1.8vw, 24px);
    height: 66px;
    display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: clamp(10px, 1.4vw, 22px);
    transition: height 0.3s var(--alt-ease);
  }
  .alt-hdr.is-scrolled .alt-hdr__bar-in { height: 58px; }

  /* Logo — emblema metálico (skeuomorfismo) + wordmark en TEXTO nítido */
  .alt-hdr__logo { display: flex; align-items: center; gap: 11px; text-decoration: none; }
  .alt-hdr__mark { display: inline-flex; filter: drop-shadow(0 2px 5px rgba(166, 128, 30, 0.28)) drop-shadow(0 1px 0 rgba(255, 255, 255, 0.6)); transition: transform var(--alt-dur) var(--alt-ease); }
  .alt-hdr__mark img { display: block; height: 41px; width: auto; transition: height 0.3s var(--alt-ease); }
  .alt-hdr.is-scrolled .alt-hdr__mark img { height: 37px; }
  .alt-hdr__logo:hover .alt-hdr__mark { transform: translateY(-1px); }
  .alt-hdr__word { display: flex; flex-direction: column; line-height: 1; }
  .alt-hdr__word-name { font-family: var(--alt-font-display); font-weight: var(--alt-fw-semibold); font-size: 23px; letter-spacing: 0.17em; color: var(--alt-ink); }
  .alt-hdr__word-sub { font-size: 8.5px; font-weight: var(--alt-fw-bold); letter-spacing: 0.36em; text-transform: uppercase; color: var(--alt-link); margin-top: 4px; }

  /* Nav desktop — tab-bar con subrayado dorado que se desliza */
  .alt-hdr__nav { justify-self: center; display: flex; align-items: center; gap: clamp(1px, 0.3vw, 6px); }
  .alt-hdr__item { position: relative; }
  .alt-hdr__top { display: inline-flex; flex-direction: column; align-items: center; gap: 4px; padding: 8px 11px; font-size: 13px; font-weight: var(--alt-fw-medium); color: var(--alt-ink); text-decoration: none; white-space: nowrap; }
  .alt-hdr__top > span:first-child { display: inline-flex; align-items: center; gap: 5px; }
  .alt-hdr__cap { width: 10px; height: 10px; transition: transform var(--alt-dur) var(--alt-ease); }
  .alt-hdr__uline { height: 2.5px; width: 18px; border-radius: 2px; background: var(--alt-grad-gold-underline); opacity: 0; transform: scaleX(0.3); transition: opacity var(--alt-dur) var(--alt-ease), transform var(--alt-dur) var(--alt-ease); }
  .alt-hdr__top:hover { color: var(--alt-link); }
  .alt-hdr__item:hover .alt-hdr__uline, .alt-hdr__top[data-active='true'] .alt-hdr__uline { opacity: 1; transform: scaleX(1); }
  .alt-hdr__item:hover .alt-hdr__cap { transform: rotate(180deg); }

  /* Paneles desplegables — GLASSMORFISMO (vidrio esmerilado) */
  .alt-hdr__pan { position: absolute; top: 100%; padding-top: 15px; z-index: var(--alt-z-dropdown); opacity: 0; visibility: hidden; transform: translateY(6px); transition: opacity var(--alt-dur) var(--alt-ease), transform var(--alt-dur) var(--alt-ease), visibility var(--alt-dur); }
  .alt-hdr__pan.align-left { left: 0; }
  .alt-hdr__pan.align-right { right: 0; }
  .alt-hdr__item:hover .alt-hdr__pan, .alt-hdr__item:focus-within .alt-hdr__pan { opacity: 1; visibility: visible; transform: translateY(0); }
  .alt-hdr__pan-card {
    background: rgba(255, 255, 255, 0.78);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    backdrop-filter: saturate(180%) blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: var(--alt-r-lg);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9), 0 34px 76px -34px rgba(6, 39, 67, 0.4), 0 4px 14px -10px rgba(27, 39, 51, 0.14);
    padding: 22px; display: flex; gap: 26px;
  }
  @supports not ((-webkit-backdrop-filter: blur(1px)) or (backdrop-filter: blur(1px))) { .alt-hdr__pan-card { background: var(--alt-white); } }
  .alt-hdr__col { min-width: 150px; }
  .alt-hdr__col-h { margin: 0 10px 8px; }
  .alt-hdr__lnk { display: block; padding: 8px 10px; border-radius: var(--alt-r-sm); font-size: 13.5px; font-weight: var(--alt-fw-medium); color: var(--alt-text); text-decoration: none; white-space: nowrap; transition: background var(--alt-dur) var(--alt-ease), color var(--alt-dur) var(--alt-ease); }
  .alt-hdr__lnk:hover { background: rgba(255, 255, 255, 0.7); color: var(--alt-link); }
  .alt-hdr__rich { display: flex; flex-direction: column; gap: 6px; width: 288px; }
  .alt-hdr__richlnk { display: flex; gap: 13px; align-items: flex-start; padding: 12px; border-radius: var(--alt-r-sm); text-decoration: none; transition: background var(--alt-dur) var(--alt-ease); }
  .alt-hdr__richlnk:hover { background: rgba(255, 255, 255, 0.7); }
  /* icono rich — chip neumórfico suave */
  .alt-hdr__richicon { flex: none; width: 40px; height: 40px; border-radius: 12px; background: var(--alt-surface-neu); box-shadow: var(--alt-nm-up-sm); display: inline-flex; align-items: center; justify-content: center; color: var(--alt-gold-raw); }
  .alt-hdr__richicon svg { width: 19px; height: 19px; }
  .alt-hdr__richt { display: block; font-size: 14px; font-weight: var(--alt-fw-semibold); color: var(--alt-ink); }
