---
/*
 * Header / navegación COMPARTIDA (Ola 1). Réplica de ALTORRA Header.dc.html, tokenizada
 * al design system D1 y con el CONTACTO REAL (los mockups traían placeholders falsos).
 * Disciplina de color: solo paleta. 3 capas: barra utilitaria + barra glass + drawer móvil.
 * Props: active = clave del ítem de nav actual (subraya el activo).
 */
import { SITE } from '../lib/config/site';

interface Props {
  active?: string;
}
const { active = '' } = Astro.props;

// Íconos SVG (línea, stroke=currentColor) — set:html donde se usan.
const icon = {
  pin: '<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="2.6"/>',
  phone: '<path d="M4 5c0 8.8 6.2 15 15 15l1.5-3.3-4.4-1.8-1.9 2a12 12 0 0 1-5.6-5.6l2-1.9L6.3 3.5 3 5z"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2.5"/><path d="m4 7 8 6 8-6"/>',
  caret: '<path d="M6 9l6 6 6-6"/>',
  heart: '<path d="M20.8 5.6a5.5 5.5 0 0 0-7.8 0L12 6.6l-1-1a5.5 5.5 0 1 0-7.8 7.8l1 1L12 21l7.8-7.8 1-1a5.5 5.5 0 0 0 0-7.6z"/>',
  user: '<circle cx="12" cy="8" r="3.4"/><path d="M5.5 20a6.5 6.5 0 0 1 13 0"/>',
  upload: '<path d="M3 11.4 12 4l9 7.4"/><path d="M5 9.8V20h14V9.8"/><path d="M10 20v-6h4v6"/>',
  burger: '<path d="M4 7h16"/><path d="M4 12h16"/><path d="M4 17h16"/>',
  check: '<path d="M20 7 9 18l-5-5"/>',
  edit: '<path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/>',
  home: '<path d="M3 21V9l9-6 9 6v12"/><path d="M9 21v-6h6v6"/>',
  chart: '<path d="M4 19V5"/><path d="m4 15 5-5 4 4 7-8"/>',
  ig: '<rect x="3.5" y="3.5" width="17" height="17" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.4" cy="6.6" r="1.1" fill="currentColor" stroke="none"/>',
  wa: '<path d="M20 11.5a8 8 0 0 1-11.8 7L4 20l1.6-4A8 8 0 1 1 20 11.5z"/><path d="M9 9.5c0 3 2.5 5.5 5.5 5.5.6 0 1.2-.6 1.2-1.2l-1.7-1-.9.9c-1-.4-1.8-1.2-2.2-2.2l.9-.9-1-1.7C10.1 8.3 9.5 8.9 9 9.5z"/>',
};

// Modelo de navegación (data-driven). tipo: 'mega' (columnas + featured) | 'rich' (enlaces con ícono) | 'link'.
const nav = [
  {
    key: 'comprar', label: 'Comprar', href: '/comprar', type: 'mega',
    cols: [
      { title: 'Por estado', links: [['Compra nuevo', '/comprar'], ['Compra usado', '/comprar']] },
      { title: 'Por tipo', links: [['Apartamentos', '/comprar'], ['Casas', '/comprar'], ['Penthouse', '/comprar'], ['Locales', '/comprar'], ['Lotes', '/comprar'], ['Fincas', '/comprar']] },
    ],
    featured: { img: '/assets/estate-golden.webp', eyebrow: 'Destacada', title: 'Penthouse en Bocagrande', href: '/comprar' },
  },
  {
    key: 'arrendar', label: 'Arrendar', href: '/arrendar', type: 'mega',
    cols: [
      { title: 'Por zona', links: [['Zona Norte', '/arrendar'], ['Centro Histórico', '/arrendar'], ['Bocagrande', '/arrendar'], ['Castillogrande', '/arrendar'], ['Manga', '/arrendar'], ['Getsemaní', '/arrendar']] },
      { title: 'Por tipo', links: [['Apartamentos', '/arrendar'], ['Casas', '/arrendar'], ['Penthouse', '/arrendar'], ['Locales', '/arrendar'], ['Fincas', '/arrendar']] },
    ],
  },
  {
    key: 'vender', label: 'Vender', href: '/publicar', type: 'rich', align: 'left',
    rich: [
      { icon: 'check', title: 'Lo vendemos por ti', sub: 'Avalúo, marketing y cierre, todo gestionado.', href: '/publicar' },
      { icon: 'edit', title: 'Véndelo tú mismo', sub: 'Publica y administra desde tu panel.', href: '/publicar' },
    ],
  },
  {
    key: 'estancia', label: 'Corta estancia', href: '/estancias', type: 'mega', align: 'right',
    cols: [
      { title: 'Experiencias', links: [['Frente al mar', '/estancias'], ['Zona Colonial', '/estancias'], ['Zona Amurallada', '/estancias'], ['Rooftop & Piscina', '/estancias'], ['Zona Campestre', '/estancias']] },
    ],
    featured: { img: '/assets/villa-pool.webp', eyebrow: 'Estancias premium', title: 'Terrazas frente a la bahía', href: '/estancias' },
  },
  {
    key: 'turismo', label: 'Turismo', href: '/turismo', type: 'rich', align: 'right',
    rich: [
      { icon: 'home', title: 'Turismo Inmobiliario', sub: 'Estadías, guías, fotografía y pasadías.', href: '/turismo' },
      { icon: 'chart', title: 'Asesoría de Inversión Turística', sub: 'Rentabilidad y compra con retorno.', href: '/turismo#inversion' },
    ],
    featured: { img: '/assets/villa-modern.webp', eyebrow: 'Cartagena te espera', title: 'Vive la ciudad amurallada', href: '/turismo' },
  },
  {
    key: 'servicios', label: 'Servicios', href: '#servicios', type: 'mega', align: 'right',
    cols: [
      { title: 'Gestión', links: [['Administración y Arriendo', '#servicios'], ['Compra & Venta', '#servicios'], ['Avalúos', '#servicios'], ['Gerencia de Proyectos', '#servicios']] },
      { title: 'Financiero & Marketing', links: [['Marketing Inmobiliario', '#servicios'], ['Crédito de Vivienda', '#servicios'], ['Pagos en Línea', '#servicios']] },
    ],
  },
  { key: 'nosotros', label: 'Nosotros', href: '#nosotros', type: 'link' },
  { key: 'contacto', label: 'Contacto', href: '#contacto', type: 'link' },
];
---

<header class="alt-hdr">
  <!-- Capa 1: barra utilitaria -->
  <div class="alt-hdr__util">
    <div class="alt-hdr__util-in">
      <div class="alt-hdr__util-info">
        <span><svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={icon.pin}></svg>{SITE.city}</span>
        <a href={SITE.contact.whatsappLink}><svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={icon.phone}></svg>{SITE.contact.whatsapp}</a>
        <a href={`mailto:${SITE.contact.email}`}><svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={icon.mail}></svg>{SITE.contact.email}</a>
        <span class="alt-hdr__hours">Lun–Sáb · 8:00–18:00</span>
      </div>
      <div class="alt-hdr__soc">
        <a href={SITE.social.instagram} aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" set:html={icon.ig}></svg></a>
        <a href={SITE.contact.whatsappLink} aria-label="WhatsApp"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={icon.wa}></svg></a>
      </div>
    </div>
  </div>

  <!-- Capa 2: barra principal (liquid glass) -->
  <div class="alt-hdr__bar alt-nav-glass">
    <div class="alt-hdr__bar-in">
      <a class="alt-hdr__logo" href="/" aria-label={`${SITE.name} — inicio`}>
        <img src="/assets/altorra-mark-t.webp" alt="" width="40" height="40" />
        <img src="/assets/altorra-word-t.webp" alt={SITE.name} height="26" />
      </a>

      <nav class="alt-hdr__nav" aria-label="Principal">
        {nav.map((item) => (
          <div class={`alt-hdr__item${item.type !== 'link' ? ' has-mega' : ''}`}>
            <a class="alt-hdr__top" href={item.href} aria-current={active === item.key ? 'page' : undefined} data-active={active === item.key}>
              <span>
                {item.label}
                {item.type !== 'link' && <svg class="alt-hdr__cap" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" set:html={icon.caret} />}
              </span>
              <span class="alt-hdr__uline"></span>
            </a>

            {item.type !== 'link' && (
              <div class={`alt-hdr__pan align-${item.align || 'left'}`}>
                <div class="alt-hdr__pan-card">
                  {item.type === 'mega' && item.cols?.map((col) => (
                    <div class="alt-hdr__col">
                      <p class="alt-eyebrow alt-hdr__col-h">{col.title}</p>
                      {col.links.map(([t, h]) => <a class="alt-hdr__lnk" href={h}>{t}</a>)}
                    </div>
                  ))}
                  {item.type === 'rich' && (
                    <div class="alt-hdr__rich">
                      {item.rich?.map((r) => (
                        <a class="alt-hdr__richlnk" href={r.href}>
                          <span class="alt-hdr__richicon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icon[r.icon]}></svg></span>
                          <span><span class="alt-hdr__richt">{r.title}</span><span class="alt-hdr__richs">{r.sub}</span></span>
                        </a>
                      ))}
                    </div>
                  )}
                  {item.featured && (
                    <a class="alt-hdr__feat" href={item.featured.href}>
                      <img src={item.featured.img} alt="" loading="lazy" decoding="async" />
                      <span class="alt-hdr__feat-body">
                        <span class="alt-hdr__feat-eb">{item.featured.eyebrow}</span>
                        <span class="alt-hdr__feat-t">{item.featured.title}</span>
                      </span>
                    </a>
                  )}
                </div>
              </div>
            )}
          </div>
        ))}
      </nav>

      <div class="alt-hdr__actions">
        <a class="alt-hdr__fav" href="/favoritos" aria-label="Favoritos"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icon.heart}></svg></a>
        <a class="alt-hdr__login" href="/ingresar"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" set:html={icon.user}></svg>Ingresar</a>
        <a class="alt-hdr__pub" href="/publicar"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" set:html={icon.upload}></svg>Publica tu inmueble</a>
        <button class="alt-hdr__burger" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="alt-drawer" data-drawer-toggle>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" set:html={icon.burger}></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Capa 3: drawer móvil -->
  <div class="alt-hdr__drawer" id="alt-drawer" data-open="false">
    {nav.filter((n) => n.type !== 'link').map((item) => (
      <details class="alt-hdr__det">
        <summary>{item.label}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" set:html={icon.caret}></svg></summary>
        <div class="alt-hdr__det-links">
          {item.type === 'mega' && item.cols?.flatMap((c) => c.links).map(([t, h]) => <a href={h}>{t}</a>)}
          {item.type === 'rich' && item.rich?.map((r) => <a href={r.href}>{r.title}</a>)}
        </div>
      </details>
    ))}
    <a class="alt-hdr__det-flat" href="#nosotros">Nosotros</a>
    <a class="alt-hdr__det-flat" href="#contacto">Contacto</a>
    <div class="alt-hdr__drawer-cta">
      <a class="alt-hdr__pub" href="/publicar">Publica tu inmueble</a>
      <a class="alt-hdr__login" href="/ingresar" style="justify-content:center">Ingreso / Registro</a>
    </div>
  </div>
</header>

<style>
  .alt-hdr {
    position: sticky;
    top: 0;
    z-index: var(--alt-z-header);
  }
  .alt-hdr svg { width: 100%; height: 100%; }

  /* Capa 1: util */
  .alt-hdr__util {
    background: var(--alt-mist);
    border-bottom: 1px solid var(--alt-hairline);
  }
  .alt-hdr__util-in {
    max-width: var(--alt-container);
    margin-inline: auto;
    padding-inline: var(--alt-gutter);
    min-height: 30px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--alt-space-5);
  }
  .alt-hdr__util-info {
    display: flex;
    align-items: center;
    gap: var(--alt-space-5);
    font-size: var(--alt-fs-xs);
    color: var(--alt-text);
    min-width: 0;
  }
  .alt-hdr__util-info span,
  .alt-hdr__util-info a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    color: inherit;
    text-decoration: none;
  }
  .alt-hdr__util-info svg { width: 12px; height: 12px; stroke: var(--alt-gold-raw); flex: none; }
  .alt-hdr__util-info a:hover { color: var(--alt-link); }
  .alt-hdr__hours { color: var(--alt-text-muted); }
  .alt-hdr__soc { display: flex; align-items: center; gap: var(--alt-space-4); flex: none; }
  .alt-hdr__soc a { display: inline-flex; width: 15px; height: 15px; color: var(--alt-text); transition: color var(--alt-dur) var(--alt-ease); }
  .alt-hdr__soc a:hover { color: var(--alt-link); }

  /* Capa 2: barra glass */
  .alt-hdr__bar { position: relative; transition: box-shadow var(--alt-dur) var(--alt-ease); }
  .alt-hdr__bar.is-scrolled { box-shadow: var(--alt-elev-nav-scroll); }
  .alt-hdr__bar-in {
    max-width: var(--alt-container);
    margin-inline: auto;
    padding-inline: var(--alt-gutter);
    height: 66px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: clamp(10px, 1.4vw, 22px);
  }
  .alt-hdr__logo { display: flex; align-items: center; gap: 9px; }
  .alt-hdr__logo img { display: block; width: auto; }
  .alt-hdr__logo img:first-child { height: 40px; }
  .alt-hdr__logo img:last-child { height: 26px; }

  /* Nav desktop */
  .alt-hdr__nav { justify-self: center; display: flex; align-items: center; gap: clamp(1px, 0.3vw, 6px); }
  .alt-hdr__item { position: relative; }
  .alt-hdr__top {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 7px 10px;
    font-size: 13px;
    font-weight: var(--alt-fw-medium);
    color: var(--alt-ink);
    text-decoration: none;
    white-space: nowrap;
  }
  .alt-hdr__top > span:first-child { display: inline-flex; align-items: center; gap: 5px; }
  .alt-hdr__cap { width: 10px; height: 10px; transition: transform var(--alt-dur) var(--alt-ease); }
  .alt-hdr__uline { height: 2px; width: 16px; border-radius: 2px; background: var(--alt-gold); opacity: 0; transform: scaleX(0.4); transition: opacity var(--alt-dur) var(--alt-ease), transform var(--alt-dur) var(--alt-ease); }
  .alt-hdr__top:hover { color: var(--alt-link); }
  .alt-hdr__item:hover .alt-hdr__uline,
  .alt-hdr__top[data-active='true'] .alt-hdr__uline { opacity: 1; transform: scaleX(1); }
  .alt-hdr__item:hover .alt-hdr__cap { transform: rotate(180deg); }

  /* Paneles dropdown (CSS hover + focus-within) */
  .alt-hdr__pan {
    position: absolute;
    top: 100%;
    padding-top: 16px;
    z-index: var(--alt-z-dropdown);
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity var(--alt-dur) var(--alt-ease), transform var(--alt-dur) var(--alt-ease), visibility var(--alt-dur);
  }
  .alt-hdr__pan.align-left { left: 0; }
  .alt-hdr__pan.align-right { right: 0; }
  .alt-hdr__item:hover .alt-hdr__pan,
  .alt-hdr__item:focus-within .alt-hdr__pan { opacity: 1; visibility: visible; transform: translateY(0); }
  .alt-hdr__pan-card {
    background: var(--alt-white);
    border: 1px solid var(--alt-hairline);
    border-radius: var(--alt-r-lg);
    box-shadow: 0 34px 76px -36px rgba(6, 39, 67, 0.36), 0 4px 14px -10px rgba(27, 39, 51, 0.12);
    padding: 22px;
    display: flex;
    gap: 26px;
  }
  .alt-hdr__col { min-width: 150px; }
  .alt-hdr__col-h { margin: 0 10px 8px; }
  .alt-hdr__lnk {
    display: block;
    padding: 8px 10px;
    border-radius: var(--alt-r-sm);
    font-size: 13.5px;
    font-weight: var(--alt-fw-medium);
    color: var(--alt-text);
    text-decoration: none;
    white-space: nowrap;
    transition: background var(--alt-dur) var(--alt-ease), color var(--alt-dur) var(--alt-ease);
  }
  .alt-hdr__lnk:hover { background: var(--alt-mist); color: var(--alt-link); }
  .alt-hdr__rich { display: flex; flex-direction: column; gap: 6px; width: 288px; }
  .alt-hdr__richlnk { display: flex; gap: 13px; align-items: flex-start; padding: 12px; border-radius: var(--alt-r-sm); text-decoration: none; transition: background var(--alt-dur) var(--alt-ease); }
  .alt-hdr__richlnk:hover { background: var(--alt-mist); }
  .alt-hdr__richicon { flex: none; width: 38px; height: 38px; border-radius: var(--alt-r-chip, 10px); background: var(--alt-mist); display: inline-flex; align-items: center; justify-content: center; color: var(--alt-gold-raw); }
  .alt-hdr__richicon svg { width: 19px; height: 19px; }
  .alt-hdr__richt { display: block; font-size: 14px; font-weight: var(--alt-fw-semibold); color: var(--alt-ink); }
  .alt-hdr__richs { display: block; font-size: 12px; color: var(--alt-text); margin-top: 2px; }

  /* Featured card en dropdown */
  .alt-hdr__feat { position: relative; width: 206px; flex: none; border-radius: var(--alt-r-frame, 14px); overflow: hidden; min-height: 216px; display: flex; align-items: flex-end; text-decoration: none; }
  .alt-hdr__feat img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .alt-hdr__feat::after { content: ''; position: absolute; inset: 0; background: var(--alt-overlay-navy); }
  .alt-hdr__feat-body { position: relative; padding: 16px; }
  .alt-hdr__feat-eb { display: block; font-size: 9.5px; font-weight: var(--alt-fw-bold); letter-spacing: 0.16em; text-transform: uppercase; color: var(--alt-gold-bright); margin-bottom: 6px; }
  .alt-hdr__feat-t { display: block; font-family: var(--alt-font-display); font-weight: var(--alt-fw-semibold); font-size: 19px; line-height: 1.08; color: #fff; }

  /* Acciones */
  .alt-hdr__actions { justify-self: end; display: flex; align-items: center; gap: 11px; flex: none; }
  .alt-hdr__fav {
    display: inline-flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; border-radius: 50%;
    border: 1px solid var(--alt-track); color: var(--alt-text);
    transition: border-color var(--alt-dur) var(--alt-ease), color var(--alt-dur) var(--alt-ease);
  }
  .alt-hdr__fav svg { width: 18px; height: 18px; }
  .alt-hdr__fav:hover { border-color: var(--alt-gold); color: var(--alt-link); }
  .alt-hdr__login {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 10px 16px; border-radius: var(--alt-r-pill);
    background: var(--alt-ink); color: #fff;
    font-weight: var(--alt-fw-semibold); font-size: 13px; white-space: nowrap; text-decoration: none;
    transition: transform var(--alt-dur) var(--alt-ease);
  }
  .alt-hdr__login svg { width: 15px; height: 15px; }
  .alt-hdr__login:hover { transform: translateY(-1px); }
  .alt-hdr__pub {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 18px; border-radius: var(--alt-r-pill);
    background: var(--alt-grad-gold); color: var(--alt-ink);
    font-weight: var(--alt-fw-bold); font-size: 13px; white-space: nowrap; text-decoration: none;
    box-shadow: 0 8px 20px -10px rgba(166, 128, 30, 0.55);
    transition: transform var(--alt-dur) var(--alt-ease);
  }
  .alt-hdr__pub svg { width: 16px; height: 16px; }
  .alt-hdr__pub:hover { transform: translateY(-1px); }
  .alt-hdr__burger {
    display: none;
    width: 44px; height: 44px; border-radius: var(--alt-r-sm);
    border: 1px solid var(--alt-track); background: var(--alt-white); color: var(--alt-ink);
    align-items: center; justify-content: center;
  }
  .alt-hdr__burger svg { width: 22px; height: 22px; }

  /* Drawer móvil */
  .alt-hdr__drawer {
    position: absolute;
    top: 100%; left: 0; right: 0;
    background: var(--alt-white);
    border-bottom: 1px solid var(--alt-hairline-2);
    box-shadow: 0 34px 60px -30px rgba(6, 39, 67, 0.4);
    max-height: calc(100vh - 120px);
    overflow: auto;
    padding: 12px clamp(16px, 5vw, 26px) 22px;
    z-index: var(--alt-z-drawer);
    display: none;
  }
  .alt-hdr__drawer[data-open='true'] { display: block; }
  .alt-hdr__det { border-bottom: 1px solid var(--alt-hairline); }
  .alt-hdr__det summary {
    display: flex; align-items: center; justify-content: space-between;
    padding: 13px 6px; font-size: 16px; font-weight: var(--alt-fw-semibold);
    color: var(--alt-ink); cursor: pointer; list-style: none;
  }
  .alt-hdr__det summary::-webkit-details-marker { display: none; }
  .alt-hdr__det summary svg { width: 16px; height: 16px; color: var(--alt-text-muted); transition: transform var(--alt-dur) var(--alt-ease); }
  .alt-hdr__det[open] summary svg { transform: rotate(180deg); }
  .alt-hdr__det-links { padding: 2px 6px 12px; display: flex; flex-wrap: wrap; gap: 6px 18px; }
  .alt-hdr__det-links a { color: var(--alt-text); font-size: 14px; padding: 6px 0; text-decoration: none; }
  .alt-hdr__det-flat { display: block; padding: 13px 6px; font-size: 16px; font-weight: var(--alt-fw-semibold); color: var(--alt-ink); text-decoration: none; border-bottom: 1px solid var(--alt-hairline); }
  .alt-hdr__drawer-cta { display: flex; flex-direction: column; gap: 10px; margin-top: 18px; }
  .alt-hdr__drawer-cta .alt-hdr__pub,
  .alt-hdr__drawer-cta .alt-hdr__login { padding: 14px; border-radius: var(--alt-r-sm); font-size: 14px; }

  /* Responsive: colapso desktop↔móvil a 1300px (breakpoint único del sistema) */
  @media (max-width: 1299px) {
    .alt-hdr__nav, .alt-hdr__fav, .alt-hdr__login, .alt-hdr__pub, .alt-hdr__util { display: none; }
    .alt-hdr__burger { display: inline-flex; }
    .alt-hdr__bar-in { grid-template-columns: auto 1fr; }
    .alt-hdr__actions { grid-column: 2; }
  }
  @media (min-width: 1300px) {
    .alt-hdr__burger { display: none; }
  }
</style>

<script>
  // Drawer + sombra al scroll — vanilla, mínimo.
  const hdr = document.querySelector('.alt-hdr');
  const bar = hdr?.querySelector('.alt-hdr__bar');
  const drawer = document.getElementById('alt-drawer');
  const toggle = hdr?.querySelector('[data-drawer-toggle]');

  toggle?.addEventListener('click', () => {
    const open = drawer?.getAttribute('data-open') === 'true';
    drawer?.setAttribute('data-open', String(!open));
    toggle.setAttribute('aria-expanded', String(!open));
    toggle.setAttribute('aria-label', open ? 'Abrir menú' : 'Cerrar menú');
  });

  // Cierra el drawer al pasar a desktop (breakpoint 1300, unificado CSS↔JS).
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1300 && drawer?.getAttribute('data-open') === 'true') {
      drawer.setAttribute('data-open', 'false');
      toggle?.setAttribute('aria-expanded', 'false');
    }
  });

  // Sombra de la barra al scrollear (>6px).
  const onScroll = () => bar?.classList.toggle('is-scrolled', window.scrollY > 6);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
