<script>
  // Drawer (morph hamburguesa↔X) + condensado al scroll (colapsa util + achica barra).
  const hdr = document.querySelector('.alt-hdr');
  const drawer = document.getElementById('alt-drawer');
  const toggle = hdr?.querySelector('[data-drawer-toggle]');

  toggle?.addEventListener('click', () => {
    const open = drawer?.getAttribute('data-open') === 'true';
    drawer?.setAttribute('data-open', String(!open));
    toggle.setAttribute('aria-expanded', String(!open));
    toggle.setAttribute('aria-label', open ? 'Abrir menú' : 'Cerrar menú');
    hdr?.toggleAttribute('data-drawer-open', !open);
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1300 && drawer?.getAttribute('data-open') === 'true') {
      drawer.setAttribute('data-open', 'false');
      toggle?.setAttribute('aria-expanded', 'false');
      hdr?.removeAttribute('data-drawer-open');
    }
  });

  // Condensado al scrollear (>8px): colapsa la barra utilitaria y achica la barra flotante.
  const onScroll = () => hdr?.classList.toggle('is-scrolled', window.scrollY > 8);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
